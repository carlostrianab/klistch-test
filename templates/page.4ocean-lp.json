        "a27af366-b4cc-4629-b4db-d3a27b9d2b9b": {
          "type": "text",
          "settings": {
            "text": "<p><strong>Did you know? <br\/><\/strong><br\/>Over 18 billion pounds of plastic enter the ocean each year. By choosing Kitsch, you're actively contributing to reducing that number. <br\/><br\/>Every shampoo and conditioner purchase have a direct impact, enabling the <strong>removal of over 233,000 pounds of trash<\/strong> from the world’s oceans & coastlines. <br\/><br\/>With the support of individual consumers, Kitsch and 4ocean will <strong>remove the equivalent of over 1.5 million plastic shampoo bottles <\/strong>from the oceans, rivers, and coastlines through this Buy One\/Pull One campaign.<\/p><p><\/p>",
            "text_font": "font-default",
            "font_size": 16,
            "text_align": "text-center",
            "font_size_mobile": 16,
            "text_align_mobile": "text-left"
          }
        }
