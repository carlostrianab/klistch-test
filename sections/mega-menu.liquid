            {
                "value": "lg:grid-cols-1",
                "label": "1 columns"
            },
            {
                "value": "lg:grid-cols-2",
                "label": "2 columns"
            },
            {
                "value": "lg:grid-cols-3",
                "label": "3 columns"
            },
            {
                "value": "lg:grid-cols-4",
                "label": "4 columns"
            },
            {
                "value": "lg:grid-cols-5",
                "label": "5 columns"
            },
            {
                "value": "lg:grid-cols-6",
                "label": "6 columns"
            }
        ]
    },
    {
        "type": "select",
        "id": "grid_tablet",
        "label": "Grid Tablet",
        "default": "md:grid-cols-3",
        "options": [
            {
                "value": "md:grid-cols-1",
                "label": "1 columns"
            },
            {
                "value": "md:grid-cols-2",
                "label": "2 columns"
            },
            {
                "value": "md:grid-cols-3",
                "label": "3 columns"
            },
            {
                "value": "md:grid-cols-4",
                "label": "4 columns"
            },
            {
                "value": "md:grid-cols-5",
                "label": "5 columns"
            },
            {
                "value": "md:grid-cols-6",
                "label": "6 columns"
            }
        ]
    },
    {
      "type": "select",
      "id": "grid_mobile",
      "label": "Grid Mobile",
      "default": "grid-cols-2",
      "options": [
          {
              "value": "grid-cols-1",
              "label": "1 columns"
          },
          {
              "value": "grid-cols-2",
              "label": "2 columns"
          },
          {
              "value": "grid-cols-3",
              "label": "2 columns"
          },
          {
              "value": "grid-cols-4",
              "label": "4 columns"
          }
      ]
    },
    {
      "type": "select",
      "id": "gap",
      "label": "Item gap",
      "default": "gap-4",
      "options": [
          {
