<div x-data class="mega-menu-section">
    {% capture megaMenu %}
      <div class="hidden-section__blocks header__menu-dropdown bg-white divide-y md:divide-y-0 text-left
      md:gap-3">
        <div class="md:px-4 {{ section.settings.container }}">
            <div class="{% if section.settings.column %} grid
                {{ section.settings.grid_desktop }} 
                {{ section.settings.grid_tablet }}  
                {{ section.settings.grid_mobile }}
                gap-x-4
                divide-y
                divide-gray-200
                md:divide-y-0
                md:py-3
            {% endif %}">
                {%- for block in section.blocks -%}
                    {%- case block.type -%}
                        {%- when 'image' -%}
                            {% if block.settings.image != blank %}
                            <div class="megamenu-image flex gap-3 md:gap-1 items-center md:flex-col">
                                <a href="{{ block.settings.button_link}}" class="block w-24 md:w-full" title="{{ block.settings.button_text }}">
                                  {% render 'img-mobile', image: block.settings.image %}
                                </a>
                                
                                {% if block.settings.button_text != blank %}
                                <a href="{{ block.settings.button_link }}" 
                                    class="{{ block.settings.button_style }} {{ block.settings.text_align }} uppercase py-2 text-sm block" 
                                    title="{{ block.settings.button_text }}">
                                    {{ block.settings.button_text }}
                                </a>
                                {% endif %}
                            </div>
                            {% endif %}
        
                        {%- when 'text' -%}
                            <div class="megamenu-text text-sm tracking-normal font-secondary {{ block.settings.text_align }}" {{ block.shopify_attributes }}>
                            {% if block.settings.heading != blank %}
                                <h2 class="text-xl md:text-2xl mb-2 {{ block.settings.text_align }}" {{ block.shopify_attributes }}>
                                    {{ block.settings.heading }}
                                </h2>
                            {% endif %}
                            {{ block.settings.text }}
                            </div>
        
                        {%- when 'menu' -%}
                          <div class="megamenu-submenu
                          {% if block.settings.heading != blank %}
                            ml-2 mb-2 
                          {% endif %}
                            md:ml-0 text-sm tracking-normal font-secondary {{ block.settings.text_align }}" 
                            x-data="{
                              submenu: true, 
                              viewChange(){
                                // on mobile, hide submenu
                                {% if block.settings.heading != blank %}
                                  this.submenu = true;
                                  $dispatch('hasheading', false);
                                {% else %}
                                  $dispatch('hasheading', true);
                                  (window.innerWidth < 768) ? this.submenu = false : this.submenu = true;
                                {% endif %}
                              }
                            }"
                            x-init="viewChange()"
                            @resize.window="viewChange();"
                            {{ block.shopify_attributes }}>
              
                            {% if block.settings.heading != blank %}
                              <h3 class="text-base md:text-xl mb-2 {{ block.settings.text_align }}" {{ block.shopify_attributes }}>
                                {% if block.settings.heading_link != blank %}
                                  <a href="{{ block.settings.heading_link }}">{{ block.settings.heading }} </a>
                                {% else %}
                                  {{ block.settings.heading }}
                                {% endif %}
                              </h3>
                            {% endif %}
              
                            {% if block.settings.menu != blank %}
                              {% unless block.settings.hide_default_title %}
                                <h3 class="text-base md:text-xl mb-2 hidden md:block">
                                  {% if block.settings.heading_link != blank %}
                                    <a href="{{ block.settings.heading_link }}">{{ linklists[block.settings.menu].title }} </a>
                                  {% else %}
                                    {{ linklists[block.settings.menu].title }}
                                  {% endif %}
                                </h3>
              
                                <button type="button" @click="submenu = !submenu" class="text-base py-2 uppercase font-medium w-full items-center flex md:hidden justify-between gap-4">
                                    {{ linklists[block.settings.menu].title }}
                                    <span class="border-l border-gray-400 pl-3">
                                        {% render 'icon-chevron-down', class: "h-6 transform no-hover mx-auto", bindClass: "{' rotate-180 ': submenu }" %}
                                    </span>
                                </button>
                              {% endunless %}
                              <ul x-show="submenu">
                                {%- for link in block.settings.menu.links -%}
                                  <li>
                                    <a href="{{ link.url }}" 
                                      class="link link--text py-1 block font-normal
                                      {% if link.active %} list-menu__item--active{% endif %}">
                                      <span>{{ link.title }}</span>
                                    </a>
                                  </li>
                                {%- endfor -%}
                              </ul>
                            {% endif %}
                        </div>
                        
                    {%- endcase -%}
                {%- endfor -%}
            </div>
        </div>
        
      </div>
    {% endcapture %}

    <template x-teleport="#megamenu-{{ section.settings.megamenu_position }}">
        {{ megaMenu }}
    </template>

    {% comment %} <template x-teleport="#megamenu-mobile-{{ section.settings.megamenu_position }}">
        {{ megaMenu }}
    </template> {% endcomment %}
    
</div>

{% schema %}
{
  "name": "Mega menu",
  "tag": "section",
  "settings": [
    {
        "type": "header",
        "content": "Mega menu",
        "info": "This section is used for mega menu."
    },
    {
      "type": "select",
      "id": "container",
      "options": [
        {
          "value": "full-width",
          "label": "Full Width"
        },
        {
          "value": "container",
          "label": "Container"
        },
        {
          "value": "page-width",
          "label": "Page Width"
        },
        {
          "value": "large-width",
          "label": "Large Width"
        },
        {
          "value": "medium-width",
          "label": "Medium Width"
        },
        {
          "value": "small-width",
          "label": "Small Width"
        }
      ],
      "default": "page-width",
      "label": "Container"
    },
    {
        "type": "text",
        "id": "megamenu_position",
        "label": "Position",
        "info": "Which menu position to attach this mega menu to. This is the same as the menu position navigation."
    },
    {
      "type": "checkbox",
      "id": "column",
      "default": false,
      "label": "Column"
    },
    {
