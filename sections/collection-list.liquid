        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Link"
        },
        {
          "type": "checkbox",
          "id": "link_image",
          "default": true,
          "label": "Link image"
        },
        {
          "type": "header",
          "content": "Style"
        },
        {
          "type": "color",
          "id": "button_color",
          "default": "#000",
          "label": "Button color"
        },
        {
          "type": "color",
          "id": "button_bg",
          "default": "#fff",
          "label": "Button background"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection list",
      "blocks": [
        {
          "type": "featured_collection"
        },
        {
          "type": "featured_collection"
        },
        {
          "type": "featured_collection"
        }
      ]
    }
  ]
}
{% endschema %}

