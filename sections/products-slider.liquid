<style>
  #products-slider-{{ section.id }}{
      padding-top: {{ section.settings.padding_top | append: 'px' }};
      padding-bottom: {{ section.settings.padding_bottom | append: 'px' }};
  }
</style>

{% if section.settings.collection != blank or section.settings.product_list != blank %}
  <div id="products-slider-{{ section.id }}" class="products__slider {{ section.settings.class }} {{ section.settings.container }} mx-auto px-4 ">
    <div class="products__slider-wrapper" 
      {% if section.settings.slider_mode %}
        x-data="{
          mainSlider: null,
          prev() {
            this.mainSlider.prev();
          },
          next() {
            this.mainSlider.next();
          }
        }" 
        x-init="$nextTick(() => { 
          mainSlider = KeenSlider($refs.slider, {
            loop: true,
            selector: '.featured-colection__list > .keen-slider__slide',
            slides: {
              spacing: 16,
              perView: {{ section.settings.slider_desktop }},
            },
            breakpoints: {
              '(max-width: 768px)': {
                slides: {
                  spacing: 12,
                  perView: {{ section.settings.slider_tablet }},
                }
              },
              '(max-width: 500px)': {
                slides: {
                  spacing: 12,
                  perView: {{ section.settings.slider_mobile }},
                }
              },
            },
          });

      });"
      {% endif %}>

      {%- unless section.settings.heading == blank -%}
        <div class="my-4 flex justify-between items-center">
          
          {% render 'heading', options: section.settings, id: section.id %}

          {% if section.settings.show_arrows %}
            <div class="slider-arrows flex gap-2">
              <button @click="prev()" class="w-10 h-10 bg-white flex items-center justify-center">
                {% render 'icon-chevron-left' %}
                <span class="sr-only">Skip to previous slide</span>
              </button>

              <button @click="next()"  class="w-10 h-10 bg-white flex items-center justify-center">
                  {% render 'icon-chevron-right' %}
                  <span class="sr-only">Skip to next slide</span>
              </button>
            </div>
          {% endif %}

          {%- if section.settings.show_view_all and section.settings.collection != blank and section.settings.show_arrows == false -%}
              <a href="{{ section.settings.collection.url }}" class="py-2 border-b text-sm border-black font-semibold uppercase mr-4 md:mr-0">{{ 'sections.collection_list.view_all' | t }}</a>
          {%- endif -%}
        </div>
      {%- endunless -%}

      <div class="relative overflow-x-hidden">
        <ul class="
          {% if section.settings.slider_mode %}
            keen-slider featured-colection__list flex overflow-auto
          {% else %}
            grid gap-3 md:gap-4
            {{ section.settings.grid_desktop }} 
            {{ section.settings.grid_tablet }} 
            {{ section.settings.grid_mobile }}
          {% endif %} " x-ref="slider" role="list">
          {% if section.settings.collection != blank %}
            {%- for product in section.settings.collection.products limit: section.settings.products_to_show -%}
                <li class="featured-colection__item keen-slider__slide w-full" {{ block.shopify_attributes }}>
                  {% render 'card-product',
                      card_product: product,
                      show_secondary_image: section.settings.show_secondary_image,
                      show_vendor: section.settings.show_vendor,
                      show_rating: section.settings.show_rating,
                      show_sold_count: section.settings.show_sold_count,
                      image_ratio: section.settings.image_ratio,
                      show_add_to_cart: section.settings.show_add_to_cart,
                      image_loading: section.settings.image_loading
                  %}
                </li>
            {%- endfor -%}
          {% elsif section.settings.product_list != blank %}
              {%- for product in section.settings.product_list limit: section.settings.products_to_show -%}
                  <li class="featured-colection__item keen-slider__slide w-full" {{ block.shopify_attributes }}>
                    {% render 'card-product',
                      card_product: product,
                      show_secondary_image: section.settings.show_secondary_image,
                      show_vendor: section.settings.show_vendor,
                      show_rating: section.settings.show_rating,
                      show_sold_count: section.settings.show_sold_count,
                      image_ratio: section.settings.image_ratio,
                      show_add_to_cart: section.settings.show_add_to_cart,
                      image_loading: section.settings.image_loading
                    %}
                  </li>
              {%- endfor -%}
          {% else %}
            {%- for i in (1..section.settings.products_to_show) -%}
                <li class="featured-colection__item {% if section.settings.enable_swipe_mobile %} w-10/12 md:w-full flex-shrink-0 snap-center last:mr-4 {% endif %}">
                  {% render 'card-product', show_vendor: section.settings.show_vendor %}
                </li>
            {%- endfor -%}
          {% endif %}
        
        </ul>
      </div>

    </div>

    {% if section.settings.button != blank %}
      <a href="{{ section.settings.button_link }}" class="button button--white max-w-fit !font-semibold mx-auto mt-5">
        {{ section.settings.button }}
      </a>
    {% endif %}

  </div>
{% endif %}

{% schema %}
{
  "name": "Product slider",
  "class":"product-slider-section",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "class",
      "label": "Custom Class"
    },
    {
      "type": "select",
      "id": "container",
      "options": [
        {
          "value": "full-width",
          "label": "Full Width"
        },
        {
          "value": "container",
          "label": "Container"
        },
        {
          "value": "page-width",
          "label": "Page Width"
        },
        {
          "value": "large-width",
          "label": "Large Width"
        },
        {
          "value": "medium-width",
          "label": "Medium Width"
        },
        {
          "value": "small-width",
          "label": "Small Width"
        }
      ],
      "default": "page-width",
      "label": "Container"
    },
    {
      "type": "text",
      "id": "heading",
      "default": "Products slider",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "sub_heading",
      "label": "Sub heading"
    },
    {
      "type": "text",
      "id": "heading_label",
      "label": "Label",
      "info": "This text will show above the heading as a label"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "product_list",
      "id": "product_list",
      "label": "Product list",
      "info": "If you don't select a collection, you can manually select products to show"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 16,
      "step": 1,
      "default": 4,
      "label": "Maximum products to show"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "default": false,
      "label": "Enable View all",
      "info": "Show if list includes more collections than shown"
    },
    {
      "type": "text",
      "id": "button",
      "label": "More button"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Link"
    },
    {
      "type": "header",
      "content": "Product card"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image ratio",
      "options": [
        {
          "value": "aspect-auto",
          "label": "Auto"
        },
        {
          "value": "aspect-square",
          "label": "Square"
        },
        {
          "value": "aspect-portrait",
          "label": "Portrait"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "show_secondary_image",
      "default": false,
      "label": "Show second image on hover"
    },
    {
      "type": "select",
      "id": "image_loading",
      "label": "Image loading",
      "options": [
        {
          "value": "lazy",
          "label": "Lazy"
        },
        {
          "value": "eager",
          "label": "Eager"
        }
      ],
      "default": "lazy",
      "info": "Eager load if the image is above the fold"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "default": false,
      "label": "Show vendor"
    },
    {
      "type": "checkbox",
      "id": "show_add_to_cart",
      "default": false,
      "label": "Show add to cart button"
    },
    {
      "type": "checkbox",
      "id": "show_sold_count",
      "default": false,
      "label": "Show product sold count"
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "default": true,
      "label": "Show product rating",
      "info": "To display a rating, add a product rating app. [Learn more](https://help.shopify.com/manual/online-store/themes/theme-structure/theme-features#featured-collection-show-product-rating)"
    },
    {
      "type": "header",
      "content": "Slider layout"
    },
    {
      "type": "checkbox",
      "id": "slider_mode",
      "default": false,
      "label": "Slider mode"
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "default": false,
      "label": "Show arrows",
      "info": "Only applies if slider mode is enabled and replace the view all button"
    },
    {
      "type": "range",
      "id": "slider_desktop",
      "label": "Desktop slides",
      "info": "Number of items per row",
      "default": 4,
      "min": 0.5,
      "max": 8,
      "step": 0.5
    },
    {
      "type": "range",
      "id": "slider_tablet",
      "label": "Tablet slides",
      "info": "Number of items per row",
      "default": 3,
      "min": 0.5,
      "max": 8,
      "step": 0.5
    },
    {
      "type": "range",
      "id": "slider_mobile",
      "label": "Mobile slides",
      "info": "Number of items per row",
      "default": 2,
      "min": 0.5,
      "max": 8,
      "step": 0.5
    },
    {
      "type": "header",
      "content": "Grid layout"
    },
    {
      "type": "select",
      "id": "grid_desktop",
      "label": "Desktop grid",
      "info": "Number of items per row",
      "default": "lg:grid-cols-5",
      "options": [
        {
          "value": "lg:grid-cols-1",
          "label": "1 item"
        },
        {
          "value": "lg:grid-cols-2",
          "label": "2 items"
        },
        {
          "value": "lg:grid-cols-3",
          "label": "3 items"
        },
        {
          "value": "lg:grid-cols-4",
          "label": "4 items"
        },
        {
          "value": "lg:grid-cols-5",
          "label": "5 items"
        }
      ]
    },
    {
      "type": "select",
      "id": "grid_tablet",
      "label": "Tablet grid",
      "info": "Number of items per row",
      "default": "md:grid-cols-3",
      "options": [
        {
          "value": "md:grid-cols-1",
          "label": "1 item"
        },
        {
          "value": "md:grid-cols-2",
          "label": "2 items"
        },
        {
          "value": "md:grid-cols-3",
          "label": "3 items"
        },
        {
          "value": "md:grid-cols-4",
          "label": "4 items"
        },
        {
          "value": "md:grid-cols-5",
          "label": "5 items"
        }
      ]
    },
    {
      "type": "select",
      "id": "grid_mobile",
      "label": "Mobile grid",
      "info": "Number of items per row",
      "default": "grid-cols-2",
      "options": [
        {
          "value": "grid-cols-1",
          "label": "1 item"
        },
        {
          "value": "grid-cols-2",
          "label": "2 items"
        },
        {
          "value": "grid-cols-3",
          "label": "3 items"
        },
        {
          "value": "grid-cols-4",
          "label": "4 items"
        }
      ]
    },
    {
      "type": "header",
      "content": "Heading styles"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "unit": "px",
      "min": 8,
      "max": 100,
      "step": 2,
      "default": 36
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Text align",
      "default": "md:text-left",
      "options": [
        {
          "value": "md:text-left",
          "label": "Left"
        },
        {
          "value": "md:text-center",
          "label": "Center"
        },
        {
          "value": "md:text-right",
          "label": "Right"
        }
      ]
    },
    {
      "type": "select",
      "id": "font",
      "label": "Font family",
      "default": "font-heading",
      "options": [
        {
          "value": "font-primary",
          "label": "Primary"
        },
        {
          "value": "font-secondary",
          "label": "Secondary"
        },
        {
          "value": "font-heading",
          "label": "Heading"
        },
        {
          "value": "font-sophillia",
          "label": "Sophillia"
        }
      ]
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Font weight",
      "default": "font-bold",
      "options": [
        {
          "value": "font-bold",
          "label": "Bold"
        },
        {
          "value": "font-semibold",
          "label": "Semibold"
        },
        {
          "value": "font-medium",
          "label": "Medium"
        },
        {
          "value": "font-normal",
          "label": "Normal"
        }
      ]
    },
    {
      "type": "header",
      "content": "Mobile styles"
    },
    {
      "type": "range",
      "id": "font_size_mobile",
      "label": "Font size",
      "unit": "px",
      "min": 8,
      "max": 80,
      "step": 2,
      "default": 30
    },
    {
      "type": "select",
      "id": "text_align_mobile",
      "label": "Text align",
      "default": "text-left",
      "options": [
        {
          "value": "text-left",
          "label": "Left"
        },
        {
          "value": "text-center",
          "label": "Center"
        },
        {
          "value": "text-right",
          "label": "Right"
        }
      ]
    },
    {
      "type": "header",
      "content": "Section styles"
    },
    {
      "type": "range",
      "id": "padding_top",
