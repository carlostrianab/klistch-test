    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "unit": "px",
      "min": 0,
      "max": 160,
      "step": 2,
      "default": 32
    }
  ],
  "presets": [
    {
      "name": "Products slider"
    }
  ]
}
{% endschema %}
