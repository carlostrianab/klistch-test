<div class="image-grid {% unless section.settings.full_width %} page-width {% endunless %} py-8">
    {% if section.settings.title != blank %}
        <h2 class="text-center text-3xl mb-8 heading-underline">
            {{ section.settings.title }}
        </h2>
    {% endif %}
    
    <div class="grid
        {{ section.settings.grid_desktop }} 
        {{ section.settings.grid_tablet }} 
        {{ section.settings.grid_mobile }} 
        {{ section.settings.class }}
    ">
        {% for block in section.blocks %}
            <div class="grid-item relative">
                    {% if block.settings.link != blank %}
                      <a href="{{ block.settings.link }}" class="block h-full">
                    {% endif %}
                        {% if block.settings.image != blank %}
                            <img data-em-optimize src="{{ block.settings.image | img_url: '1000x' | loading: lazy }}"/>
                        {% endif %}
                        {% if block.settings.title != blank %}
                            <h3 class="grid-item__title absolute w-full z-1 bottom-0 text-center p-1.5 bg-black/30 font-bold text-white text-shadow">
                                {{ block.settings.title }}
                            </h3>
                        {% endif %}
                    {% if block.settings.link != blank %}
                      </a>
                    {% endif %}
            </div>
        {% endfor %}

    </div>
</div>

{% schema %}
{
  "name": "Image grid",
  "max_blocks": 12,
  "settings": [
    {
        "type": "checkbox",
        "id": "full_width",
        "label": "Full page",
        "default": false
    },
    {
        "type": "text",
        "id": "title",
        "label": "Title"
    },
    {
        "type": "header",
        "content": "Grid layout"
      },
      {
        "type": "select",
        "id": "grid_desktop",
        "label": "Desktop grid",
        "info": "Number of items per row",
        "default": "lg:grid-cols-5",
        "options": [
          {
            "value": "lg:grid-cols-2",
            "label": "2 item"
          },
          {
            "value": "lg:grid-cols-3",
            "label": "3 item"
          },
          {
            "value": "lg:grid-cols-4",
            "label": "4 item"
          },
          {
            "value": "lg:grid-cols-5",
            "label": "5 item"
          },
          {
            "value": "lg:grid-cols-6",
            "label": "5 item"
          }
        ]
      },
      {
        "type": "select",
        "id": "grid_tablet",
        "label": "Tablet grid",
        "info": "Number of items per row",
        "default": "md:grid-cols-3",
        "options": [
          {
            "value": "md:grid-cols-2",
            "label": "2 item"
          },
          {
            "value": "md:grid-cols-3",
            "label": "3 item"
          },
          {
            "value": "md:grid-cols-4",
            "label": "4 item"
          },
          {
            "value": "md:grid-cols-5",
            "label": "5 item"
          }
        ]
      },
      {
        "type": "select",
        "id": "grid_mobile",
        "label": "Mobile grid",
        "info": "Number of items per row",
        "default": "grid-cols-2",
        "options": [
          {
            "value": "grid-cols-1",
            "label": "1 item"
          },
          {
            "value": "grid-cols-2",
            "label": "2 item"
          },
          {
            "value": "grid-cols-3",
            "label": "3 item"
          },
          {
            "value": "grid-cols-4",
            "label": "4 item"
          }
        ]
      },
      {
        "type": "text",
        "id": "class",
        "label": "Class"
      }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "default": "Collection",
          "label": "Title"
        },
        {
            "type": "image_picker",
            "id": "image",
            "label": "Image",
            "info": "Recommended size: 600x350"
        },
        {
            "type": "url",
            "id": "link",
            "label": "Link"
        }
      ]
    },
    {
      "type": "subscription",
      "name": "subscription",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "default": "Collection",
          "label": "Title"
        },
        {
            "type": "image_picker",
            "id": "image",
            "label": "Image",
            "info": "Recommended size: 600x350"
        },
        {
            "type": "url",
            "id": "link",
            "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Image grid"
    }
  ]
}
{% endschema %}
