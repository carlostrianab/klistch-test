
<div class="video__banner relative {{ section.settings.container }} mx-auto px-4">
    {% if section.settings.overlay_image %}
      <div class="dark-overly absolute inset-0" style="background-color: rgba({{ section.settings.overlay_color.red }}, {{ section.settings.overlay_color.green }}, {{ section.settings.overlay_color.blue }}, {{ section.settings.overlay_opacity }});"></div>
    {% endif %}

    {% if section.settings.video != blank %}
        <div class="video__banner--video">
          {{ section.settings.video | video_tag: controls: false, loop: true , autoplay: true , class: 'w-full' }}
        </div>
    {% else %}
        <div class="banner__media">
            {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
        </div>
    {% endif %}

    <div class="inset-0 {% if section.settings.below_image_mobile %} relative z-30 md:absolute {% else %} absolute {% endif %}">
      <div class="{{ section.settings.image_container }} px-4 mx-auto h-full">
        <div class="banner__content inset-0 flex z-10 h-full
            {{ section.settings.vertical_alignment }} 
            {{ section.settings.horizontal_alignment }}
            {{ section.settings.vertical_alignment_mobile }}
            {{ section.settings.horizontal_alignment_mobile }}">
          <div style="max-width: {{ section.settings.max_width }}px;
              background-color: rgba({{ section.settings.content_background.red }}, {{ section.settings.content_background.green }}, {{ section.settings.content_background.blue }}, {{ section.settings.content_background_opacity }}); 
              color: {{ section.settings.text_color }};"
            class="banner__box p-4 space-y-6">
            {%- for block in section.blocks -%}
              {%- case block.type -%}
                {%- when 'heading' -%}
                  {%- render 'heading', options: block.settings, id: block.id -%}
                {%- when 'text' -%}
                  {% render 'text', block: block %}
                {%- when 'buttons' -%}
                  {% render 'buttons', block: block %}
              {%- endcase -%}
            {%- endfor -%}
          </div>

        </div>

      </div>
    </div>


</div>

