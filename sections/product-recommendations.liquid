
<style>
  #Product-recommendations-{{ section.id }}{
      padding-top: {{ section.settings.padding_top | append: 'px' }};
      padding-bottom: {{ section.settings.padding_bottom | append: 'px' }};
  }
</style>

<div id="Product-recommendations-{{ section.id }}" class="{{ section.settings.container }} mx-auto px-4 {% if section.settings.enable_swipe_mobile %} mobile-pr-0 {% endif %}">
  <div class="product-recommendations"
    x-ref="recommendations" 
    x-title="ProductRecommendation" 
    x-data="{
      url: `{{ routes.product_recommendations_url }}?section_id={{ section.id }}&product_id={{ product.id }}&limit={{ section.settings.products_to_show }}`,
      getProducts(){
        fetch(this.url)
          .then(response => response.text())
          .then(text => {
            const html = document.createElement('div');
            html.innerHTML = text;
            const recommendations = html.querySelector('.product-recommendations');
            if (recommendations && recommendations.innerHTML.trim().length) {
              this.$refs.recommendations.innerHTML = recommendations.innerHTML;

              setTimeout(() => {
                KeenSlider(this.$refs.slider, {
                  loop: true,
                  slides: {
                    spacing: 12,
                    perView: {{ section.settings.grid_desktop }},
                  },
                  breakpoints: {
                    '(max-width: 768px)': {
                      slides: {
                        spacing: 12,
                        perView: {{ section.settings.grid_tablet }},
                      }
                    },
                    '(max-width: 500px)': {
                      slides: {
                        spacing: 12,
                        perView: {{ section.settings.grid_mobile }},
                      }
                    },
                  },
                }, [UnickNavigationPlugin]);

              }, 100);

            }

          })
          .catch(e => {
            console.error(e);
          });
      }
    }" x-init="$nextTick(() => { getProducts(); });">
    {% if recommendations.performed and recommendations.products_count > 0 %}
      {%- unless section.settings.heading == blank -%}
        <div class="my-4">
          {% render 'heading', options: section.settings, id: section.id %}
        </div>
      {%- endunless -%}
      <ul x-ref="slider" class="keen-slider" role="list">
        {%- for recommendation in recommendations.products -%}
            <li class="featured-colection__item keen-slider__slide w-full" {{ block.shopify_attributes }}>
              {% render 'card-product',
                    card_product: recommendation,
                    show_secondary_image: section.settings.show_secondary_image,
                    show_vendor: section.settings.show_vendor,
                    show_rating: section.settings.show_rating,
                    show_sold_count: section.settings.show_sold_count,
                    image_ratio: section.settings.image_ratio,
                    enable_gallery: false,
              %}
            </li>
        {%- endfor -%}
      </ul>

    {% endif %}
    </div>
</div>

