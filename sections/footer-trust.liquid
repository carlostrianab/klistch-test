
<div 
    style="
    {% if section.settings.bg_image != blank %}
      background-image: url({{ section.settings.bg_image | img_url: 'master' }});
    {% endif %}
    background-color: {{ section.settings.bg_color }}; 
    padding-top: {{ section.settings.padding_top }}px; 
    padding-bottom: {{ section.settings.padding_bottom}}px;"
    class="{{ section.settings.container }} mx-auto px-4 bg-contain 2xl:bg-cover bg-bottom bg-no-repeat">
    {% if section.settings.title != blank %}
        <h2 class="{{ section.settings.align_text }} mb-4 font-bold" style="font-size: {{ section.settings.font_size }}px">{{ section.settings.title | escape }}</h2>
    {% endif %}

    <div class="{% if section.settings.content_wrapper %} page-width {% endif %}">
      <div class="icons grid 
          {{ section.settings.grid_gap }}
          {{ section.settings.grid_desktop }}
          {{ section.settings.grid_tablet }}
          {{ section.settings.grid_mobile }}">
          {% for block in section.blocks %}
              {% assign options = block.settings %}
              {% if options.use_custom_style %}
                <style>
                  .block_{{block.id}}{
                    border: 2px solid;
                    border-radius: 4px;
                    box-shadow: 0px 0px 8px rgba(0, 0, 0, 0.25);
                    background-color: {{ options.bg_color }};
                    border-color: {{ options.border_color }};
                    
                  }
  
                  .block_{{block.id}} .icon__title{
                    color: {{ options.title_color }};
                  }
                  
                  .block_{{block.id}} .icon__text{
                    padding: 1rem;
                    background-color: {{ options.text_bg }};
                  }
  
                </style>
              {% endif %}
              <div class="block_{{block.id}} icon {{ section.settings.align_text }} {% if section.settings.classic_style %} md:flex items-center justify-center {% endif %}">
                  {% if options.icon != blank %}
                      <img 
                          data-em-optimize
                          loading="lazy" 
                          class="
                          {% if section.settings.spaced_icons %}
                            py-5
                          {% endif %}
                          {% if section.settings.classic_style %} 
                            mb-2 md:mb-0 mx-auto md:ml-4 max-w-[70px] md:mr-4 
                          {% else %} 
                            mx-auto 
                          {% endif %}"
                          width="{{ section.settings.image_size | replace: 'x', '' }}"
                          height="{{ section.settings.image_size | replace: 'x', '' | divided_by: options.icon.aspect_ratio }}"
                          src="{{ options.icon | img_url: section.settings.image_size }}" alt="{{ options.icon.alt | default: shop.name | append: 'image' }}">
                  {% endif %}
  
                  {% if options.title != blank %}
                      <h3 class="icon__title font-bold py-2" 
                          style="color: {{ section.settings.text_color }}; font-size: {{ section.settings.title_font_size }}px; ">{{ options.title }}</h3>
                  {% endif %}
  
                  {% if options.text != blank %}
                      <div class="icon__text font-medium" style="color: {{ section.settings.text_color }}">
                          {{ options.text }}
                      </div>
                  {% endif %}
              </div>
          {% endfor %}
      </div>
    </div>
</div>

{% schema %}
{
  "name": "Footer trust",
  "tag": "section",
  "class": "icon-with-text",
  "settings": [
    {
      "type": "select",
      "id": "container",
      "options": [
        {
          "value": "full-width",
