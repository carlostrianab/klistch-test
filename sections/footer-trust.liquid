    {
        "type": "range",
        "id": "font_size",
        "label": "Font size",
        "unit": "px",
        "min": 8,
        "max": 50,
        "step": 2,
        "default": 24
    },
    {
        "type": "color",
        "id": "bg_color",
        "label": "Background"
    },
    {
      "type": "image_picker",
