<style>
  .login__page{
    padding-top: {{ settings.padding_top }}px;
    padding-bottom: {{ settings.padding_bottom }}px;
  }
</style>

<div class="login__page {{ section.settings.container }} mx-auto px-4">

  <div class="h-full my-6 md:my-8" x-cloak x-data="{ resetPassword: $persist(false) }">

    <header class="flex items-center justify-center mb-3">
      <h2 class="text-3xl font-heading text-center" x-text="(resetPassword) ? `{{ 'customer.recover_password.title' | t }}` : `{{ 'customer.login_page.title' | t }}` " tabindex="-1"> {{ 'customer.login_page.title' | t }} </h2>
    </header> 

    <div x-show="!resetPassword" x-transition.opacity class="h-full flex items-center justify-center">
      <div class="w-full">
          {%- form 'customer_login', novalidate: 'novalidate' -%}
            {%- if form.errors -%}
              <h2 class="flex text-base mb-2 items-center" tabindex="-1">
                <span class="sr-only">{{ 'accessibility.error' | t }} </span>
                <span class="w-7 pr-2">
                  {% render 'icon-error' %}
                </span>
                {{ 'templates.contact.form.error_heading' | t }}
              </h2>
              <div class="text-red-500 mb-2">
                {{ form.errors | default_errors }}
              </div>
            {%- endif -%}
      
            <div class="flex flex-col mb-2">
              <label for="CustomerEmail" class="form__label mb-2">
                {{ 'customer.login_page.email' | t }}
              </label>      
              <input
                type="email"
                name="customer[email]"
                id="CustomerEmail"
                autocomplete="email"
                placeholder="{{ 'customer.login_page.email' | t }}"
                autocorrect="off"
                autocapitalize="off"
                class="form__input"
                {% if form.errors contains 'form' %}
                  aria-invalid="true"
                {% endif %}
              >
             
            </div>
      
            {%- if form.password_needed -%}
              <div class="flex flex-col mb-2">   
                <label for="CustomerPassword" class="form__label my-2">
                  {{ 'customer.login_page.password' | t }}
                </label>

                <input
                  type="password"
                  value=""
                  name="customer[password]"
                  id="CustomerPassword"
                  placeholder="{{ 'customer.login_page.password' | t }}"
                  autocomplete="current-password"
                  class="form__input"
                  {% if form.errors contains 'form' %}
                    aria-invalid="true"
                  {% endif %}
                >
               
              </div>
            {%- endif -%}

            <div class="flex space-x-6 my-3">
              <button class="button button--secondary text-center">
                {{ 'customer.login_page.sign_in' | t }}
              </button>

              <button type="button" @click="resetPassword = true" class="block underline">
                {{ 'customer.login_page.forgot_password' | t }}
              </button>
            </div>
      
            <p class="my-6 space-x-2">
              {{ 'customer.login_page.create_message' | t }}
              <a href="{{ routes.account_register_url }}" class="underline">
                {{ 'customer.login_page.create_account' | t }}
              </a>
            </p>

           
            
          {%- endform -%}
      </div>
    </div>

    <div x-show="resetPassword" x-transition.opacity class="h-full flex items-center justify-center">
        <div class="w-full">

          <p class="text-sm font-secondary text-center mb-2">
            {{ 'customer.recover_password.subtext' | t }}
          </p>

          {%- if recover_success == true -%}
            <h4 class="text-xl" tabindex="-1" autofocus>
              <svg aria-hidden="true" focusable="false" role="presentation" viewBox="0 0 13 13">
                <path d="M6.5 12.35C9.73087 12.35 12.35 9.73086 12.35 6.5C12.35 3.26913 9.73087 0.65 6.5 0.65C3.26913 0.65 0.65 3.26913 0.65 6.5C0.65 9.73086 3.26913 12.35 6.5 12.35Z" fill="#428445" stroke="white" stroke-width="0.7"/>
                <path d="M5.53271 8.66357L9.25213 4.68197" stroke="white"/>
                <path d="M4.10645 6.7688L6.13766 8.62553" stroke="white">
              </svg>
              {{ 'customer.recover_password.success' | t }}
            </h3>
          {%- endif -%}

          {%- form 'recover_customer_password' -%}
            {% assign recover_success = form.posted_successfully? %}
            <div class="flex flex-col mb-4">
              <label for="RecoverEmail" class="form__label mb-2">
                  {{ 'customer.login_page.email' | t }}
              </label>
              <input type="email"
                    value=""
                    name="email"
                    id="RecoverEmail"
                    autocorrect="off"
                    autocapitalize="off"
                    autocomplete="email"
                    placeholder="{{ 'customer.login_page.email_placeholder' | t }}"
                    class="form__input"
                    {% if form.errors %}
                      aria-invalid="true"
                      aria-describedby="RecoverEmail-email-error"
                      autofocus
                    {% endif %}
              >
            
            </div>
            {%- if form.errors -%}
              <small id="RecoverEmail-email-error" class="form__message">
                <svg aria-hidden="true" focusable="false" role="presentation" viewBox="0 0 13 13">
                  <circle cx="6.5" cy="6.50049" r="5.5" stroke="white" stroke-width="2"/>
                  <circle cx="6.5" cy="6.5" r="5.5" fill="#EB001B" stroke="#EB001B" stroke-width="0.7"/>
                  <path d="M5.87413 3.52832L5.97439 7.57216H7.02713L7.12739 3.52832H5.87413ZM6.50076 9.66091C6.88091 9.66091 7.18169 9.37267 7.18169 9.00504C7.18169 8.63742 6.88091 8.34917 6.50076 8.34917C6.12061 8.34917 5.81982 8.63742 5.81982 9.00504C5.81982 9.37267 6.12061 9.66091 6.50076 9.66091Z" fill="white"/>
                  <path d="M5.87413 3.17832H5.51535L5.52424 3.537L5.6245 7.58083L5.63296 7.92216H5.97439H7.02713H7.36856L7.37702 7.58083L7.47728 3.537L7.48617 3.17832H7.12739H5.87413ZM6.50076 10.0109C7.06121 10.0109 7.5317 9.57872 7.5317 9.00504C7.5317 8.43137 7.06121 7.99918 6.50076 7.99918C5.94031 7.99918 5.46982 8.43137 5.46982 9.00504C5.46982 9.57872 5.94031 10.0109 6.50076 10.0109Z" fill="white" stroke="#EB001B" stroke-width="0.7">
                </svg>
                {{ form.errors.messages['form'] }}
              </small>
            {%- endif -%}
            
            <div class="flex space-x-6 my-3">
              <button class="button button--secondary">
                {{ 'customer.login_page.reset' | t }}
              </button>
              <button type="button" @click="resetPassword = false" class="block underline">
                {{ 'customer.login_page.cancel' | t }}
              </button>
            </div>

            <p class="my-6 space-x-2">
              {{ 'customer.login_page.create_message' | t }}
              <a href="{{ routes.account_register_url }}" class="underline">
                {{ 'customer.login_page.create_account' | t }}
              </a>
            </p>


          {%- endform -%}
        </div>
    </div>

    {%- if shop.checkout.guest_login -%}
      <div>
        <h2 class="text-2xl">{{ 'customer.login_page.guest_title' | t }}</h2>
        {%- form 'guest_login' -%}
          <button class="px-5 py-2 border border-black inline-block button-primary">
            {{ 'customer.login_page.guest_continue' | t }}
          </button>
        {%- endform -%}
      </div>
    {%- endif -%}

  </div>

</div>


{% schema %}
{
  "name": "Login page",
  "settings": [
    {
      "type": "select",
      "id": "container",
      "options": [
        {
          "value": "full-width",
          "label": "Full Width"
        },
        {
          "value": "container",
          "label": "Container"
        },
        {
          "value": "page-width",
          "label": "Page Width"
        },
        {
          "value": "large-width",
          "label": "Large Width"
        },
        {
          "value": "medium-width",
          "label": "Medium Width"
        },
        {
          "value": "small-width",
          "label": "Small Width"
        }
      ],
      "default": "small-width",
      "label": "Container"
    },
    {
      "type": "header",
      "content": "Styles"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 36
    }
  ]
}
{% endschema %}
