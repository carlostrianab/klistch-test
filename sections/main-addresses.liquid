<style>
  #Main-addresses-{{ section.id }}{
      padding-top: {{ section.settings.padding_top | append: 'px' }};
      padding-bottom: {{ section.settings.padding_bottom | append: 'px' }};
  }
</style>

{%- paginate customer.addresses by 5 -%}
<div id="Main-addresses-{{ section.id }}" class="customer addresses {{ section.settings.container }} mx-auto px-4" data-customer-addresses>

    <div>
      <h1 class="font-heading text-3xl py-5">{{ 'customer.addresses.title' | t }}</h1>
    </div>

    <div class="md:grid md:grid-cols-4 md:gap-6">
      <div class="md:col-span-1">
        {% render 'account-nav', section: section %}
      </div>
      <div class="mt-5 md:mt-0 md:col-span-3"
          x-init="province = JSON.parse($refs.address_country.selectedOptions[0].dataset.provinces);"
          x-data="{ openDelete: false, openNew: false, deleteId: null, province: [] ,openEdit: false, address: {{ customer.addresses[1] | json | escape }} }">
          <div class="sm:overflow-hidden relative">
              <div class="">
                  <h3 class="text-2xl pb-2">{{ 'customer.account.view_addresses' | t }}</h3>
                  <div class="mt-3 overflow-hidden overflow-x-auto font-medium">
                      {% paginate customer.addresses by 10 %}
                          {% if customer.addresses != 0 %}
                            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                              {% for address in customer.addresses %}
                                <div class="">
                                    {% if address == customer.default_address %}
                                        <span class="rounded-sm border text-xs px-2 py-1 mb-2 uppercase inline-block tracking-widest">{{ 'customer.addresses.default' | t }}</span>
                                    {% endif %}
  
                                    <div>
                                      {{ address | format_address }}
                                    </div>
  
                                    <div class="flex gap-4 my-4">
                                      <button @click="openEdit = true; address = {{ address | json | escape }}" class="underline">
                                          {{ 'customer.addresses.edit' | t }}
                                      </button>
          
                                      <button @click="openDelete = true; deleteId = {{ address.id }}" class="underline">
                                          {{ 'customer.addresses.delete' | t }}
                                      </button>
                                    </div>
  
                                </div>
                              {% endfor %}
                            </div>
                          {% else %}
                              <p>{{ 'customer.orders.none' | t }}</p>
                          {% endif %}
                          {% if paginate.pages > 1 %}
                              <div class="pagination">
                                  {% render 'pagination' %}
                              </div>
                          {% endif %}
                      {% endpaginate %}
                  </div>
              </div>                    

              {% render '_new-customer-address' %}
              {% render '_edit-customer-address' %}
              {% render '_delete-customer-address' %}

          </div>
      </div> 
    </div>
</div>
{%- endpaginate -%}


{% schema %}
{
  "name": "Addresses",
  "settings": [
    {
      "type": "select",
      "id": "container",
      "options": [
        {
          "value": "full-width",
          "label": "Full Width"
        },
        {
          "value": "container",
          "label": "Container"
        },
        {
          "value": "page-width",
          "label": "Page Width"
        },
        {
          "value": "large-width",
          "label": "Large Width"
        },
        {
          "value": "medium-width",
          "label": "Medium Width"
        },
        {
          "value": "small-width",
          "label": "Small Width"
        }
      ],
      "default": "page-width",
      "label": "Container"
    },
    {
      "type": "header",
      "content": "Section styles"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "unit": "px",
      "min": 0,
      "max": 160,
      "step": 2,
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "unit": "px",
      "min": 0,
      "max": 160,
      "step": 2,
      "default": 32
    }
  ]
}
{% endschema %}
