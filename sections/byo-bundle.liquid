
{% capture defaultBag %}
  {% for i in (1..section.settings.empty_placeholder) -%}
      { id: {{forloop.index}}, title: 'item', img: null, status: 'demo' }{% unless forloop.last %},{% endunless %}
  {%- endfor %}
{% endcapture %}

<div class="byo-bundle {{ section.settings.container }} mx-auto px-4" 
  x-title="Bundle builder"
  x-data="{ 
      progress: {{ section.settings.min_limit }},
      bag: [{{ defaultBag }}],
      empty_placeholder: {{ section.settings.empty_placeholder }},
      min_limit: {{ section.settings.min_limit }},
      threshold: {{ section.settings.min_limit }},
      discount_percentage: {{ section.settings.discount_percentage }},
      discount_code: '{{ section.settings.discount_code }}',
      tier_2_limit: {{ section.settings.tier_2_limit }},
      tier_2_discount_percentage: '{{ section.settings.tier_2_discount_percentage }}',
      tier_3_limit: {{ section.settings.tier_3_limit }},
      tier_3_discount_percentage: '{{ section.settings.tier_3_discount_percentage }}',
      counter: 0,
      loadingCheckout: false,
      formError: '',
      previousFocus: null,
      activeProduct: {
          title: '',
          details: ``,
          img: '',
          id: null,
          price: '',
          review: ``,
      },
      viewProductModal: false,
      addBundle(ids){
          console.log(ids);
          let idArray = ids.split(',');
          idArray.forEach(id => {
              document.getElementById('button-variant-' + id).click();
          });
      },
      addToBag(id, title, img, price){
          // create object
          let obj = {
              id: id,
              title: title,
              img: img,
              price: price,
              status: 'product'
          };
          // add object to bag
          this.bag[this.counter] = obj;
          // increment counter
          this.counter++;
          this.threshold--;
          this.viewProductModal = false;
      },
      getOriginalPrice(){
          let total = 0;
          for(let i = 0; i < this.bag.length; i++){
              if(this.bag[i].status == 'product'){
                  total += this.bag[i].price;
              }
          }
          return total;
      },
      getDiscountedPrice(){
          let total = 0;
          for(let i = 0; i < this.bag.length; i++){
              if(this.bag[i].status == 'product'){
                  total += this.bag[i].price;
              }
          }

          let final = total - (total * (this.discount_percentage / 100));

          if(this.tier_2_limit != '0' && this.counter >= this.tier_2_limit){
              final = 0;
              final = total - (total * (this.tier_2_discount_percentage / 100));
          }
          
          if(this.tier_3_limit != 0 && this.counter >= this.tier_3_limit){
              final = 0;
              final =  total - (total * (this.tier_3_discount_percentage / 100));
          }
          
          return final;
      },

      addToCart(openCart = true){
          let cartObj = [];
          for(let i = 0; i < this.bag.length; i++){
              if(this.bag[i].status == 'product'){
                  // if already in the cartObj, increment the quantity
                  let found = cartObj.find(obj => obj.id == this.bag[i].id);
                  if(found){
                      found.quantity++;
                  }else{
                      cartObj.push({
                          quantity: 1,
                          id: this.bag[i].id,
                          properties: {
                              '_byob': true,
                              '_isBundleBuilder': 'true',
                          }
                      });
                  }
              }
          }

          data = {
              method: 'POST',
              headers: {
                  'Content-Type': 'application/json'
              },
              body: JSON.stringify({items : cartObj })
          };

          fetch(routes.cart_add_url + '.js', data)
              .then(response => {
                  if (response.ok) {
                      return response.json();
                  }
                  return Promise.reject(response);
              })
              .then(response => {
                  if(openCart){
                      // Update cart with event dispatch
                      this.$dispatch('cart-updated', { cart: response });
                      // Open cart after adding product
                      this.$dispatch('toggle-cart');
                      this.formError = null;
                  }
          
              })
              .catch((error) => {
                  this.formError = 'Error adding product to cart, please try later';
              });                
      },
      checkout(){
          this.loadingCheckout = true;
          this.addToCart(false);
          // redirect to checkout and apply discount if applicable
          setTimeout(() => {
              if(this.discount_code != ''){
                  window.location.href = '/checkout?discount=' + this.discount_code;
              }else{
                  window.location.href = '/checkout';
              }

          },1000);
      },
      isInCart(id){
          // check if item is in bag
          return this.bag.some(item => item.id == id);
      },
      removeItem(id){
          // remove last item found
          this.bag.splice(this.bag.findIndex(item => item.id == id), 1);
          this.threshold++;
          this.counter--;
          if(this.bag.length < this.empty_placeholder){
              this.bag.push({ id: this.counter, title: 'item', img: null, status: 'demo' });
          }
      },
      getItemCount(id){
          // get item count
          return this.bag.filter(item => item.id == id).length;
      },

      viewProduct(title, details, img, id, price, review){
          this.activeProduct.title = title;
          this.activeProduct.details = details;
          this.activeProduct.img = img;
          this.viewProductModal = true;
          this.activeProduct.id = id;
          this.activeProduct.price = price;
          this.previousFocus = this.$event.target;
          this.activeProduct.review = review;
      },
      setSidebarTop(){
          let headerHeight = this.$refs.sticky_sidebar_head.offsetHeight;
          // change headerHeight to negative number
          headerHeight = -headerHeight;

          // set top of sidebar to header height
          if(window.innerWidth < 1024){
              this.$refs.sticky_sidebar.style.top = headerHeight + 'px';
          }
      }
  }"
  x-init="$nextTick(() => {
      if(tier_2_limit != 0 ){
          progress = tier_2_limit;
      }

      if(tier_3_limit != 0 ){
          progress = tier_3_limit;
      }

      setSidebarTop();
  }); $watch('viewProductModal', (value) => {
      if(value){
          setTimeout(() => {
              $refs.close_modal.focus();
          }, 500);
      }else{
          previousFocus.focus();
      }
  })"
  @window.resize="setSidebarTop()"
  @keyup.escape="viewProductModal = false;">


  <div class="flex flex-col-reverse lg:flex-row lg:mt-10 gap-x-4">

      <div class="w-full lg:w-8/12 space-y-8 mb-4">
          {% for block in section.blocks %}
              {% assign options = block.settings %}
              <div class="promo-block">
                  <h2 class="text-2xl mb-4 font-semibold">
                    {{ block.settings.title }}
                  </h2>
                  <div class="grid gap-3 
                  {{ section.settings.grid_desktop }}
                  {{ section.settings.grid_tablet }}
                  {{ section.settings.grid_mobile }}">
                  {% for byo_product in options.products %}
                    {% render '_byo-product', byo_product: byo_product %}
                  {% endfor %}
                  </div>
              </div>
          {% endfor %}
      </div>

      <div class="w-full lg:w-4/12 sticky top-[5.8rem] self-start mb-6 lg:-mt-44" x-ref="sticky_sidebar">
          <div class="sidebar lg:mx-4 border bg-white">
              <div class="sidebar__head bg-[#f0e4de] text-black text-center p-4" x-ref="sticky_sidebar_head">
                  <h3 class="sidebar__title text-3xl font-semibold"> {{ section.settings.sidebar_title }} </h3>
                  <span class="sidebar__subtitle">{{ section.settings.sidebar_sub_title }}</span>
                  <div class="sidebar__price flex gap-2 items-center justify-center py-2 text-base font-medium">
                      <s x-text="Unick.formatMoney(getOriginalPrice())"> $0 </s>
                      <span x-text="Unick.formatMoney(getDiscountedPrice())"> $0 </span>
                  </div>
              </div>
              <div class="sidebar__items lg:py-3 px-3">
                  <div class="progress-bar border border-gray-500 rounded-full mt-9 relative p-0.5">
                      <div class="progress-bar__inner flex">
                        <template x-for="i in progress">
                            <div class="progress-bar__fill h-2 w-20"
                              :class="{
                                'bg-[#f8b68f]': counter >= i, 
                                'rounded-l-lg': i == 1, 
                                'rounded-r-lg': i == progress,
                                'w-full': i == min_limit || i == tier_2_limit || i == tier_3_limit
                                }" :key="index">
                                <div class="absolute leading-none z-10 bottom-0  text-gray-500 flex flex-col text-center" x-show="i != 1">
                                <i x-show="i == min_limit" x-text="discount_percentage + '%'" class="text-base font-medium text-black"></i>
                                <i x-show="i == tier_2_limit" x-text="tier_2_discount_percentage + '%'" class="text-base font-medium text-black"></i>
                                <i x-show="i == tier_3_limit" x-text="tier_3_discount_percentage + '%'" class="text-base font-medium text-black"></i>
                                <span class="h-[13px] overflow-hidden" x-show="i == min_limit || i == tier_2_limit || i == tier_3_limit">|</span>
                              </div>
                            </div>
                        </template>
                      </div>
                  </div>

                  <div class="items_wrap flex lg:grid grid-cols-3 gap-4 py-4 overflow-x-scroll lg:overflow-x-visible no-scrollbar">
                      <template x-for="(item, index) in bag">
                          <div class="w-20 min-w-[80px] lg:min-w-[initial] lg:w-full">
                              <div x-show="item.status == 'demo'">
                                  <div class="border-2 border-dotted border-gray-300 h-20 w-full flex items-center justify-center rounded-md text-xl" x-text="++index"></div>
                                  <span x-text="'Product '+ index" class="text-center block py-1 text-sm"></span>
                              </div>
                              <div x-show="item.status == 'product'" class="relative">
                                  <button @click="removeItem(item.id)" aria-label="remove item" class="absolute -top-2 -right-2 text-white bg-black p-1 rounded-full">
                                      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon icon-remove"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                                  </button>
                                  <img :src="item.img" :alt="item.title" class="h-20 min-w-20 w-full mx-auto flex items-center justify-center object-cover" />
                                  <span x-text="item.title" class="text-center block py-1 text-sm"></span>
                              </div>
                          </div>
                      </template>
                  </div>

              </div>

              <div class="sidebar__footer border-t p-3 fixed bottom-0 bg-white left-0 right-0 lg:relative">

                  {% comment %} <span x-show="threshold > 0" class="border font-medium text-lg py-3 px-6 text-gray-500 border-black w-full text-center block rounded-md">
                      Select <span x-text="threshold">x</span> more products
                  </span> {% endcomment %}
                  
                  {% if section.settings.checkout_behavior == 'add_to_cart' %}
                      <button type="button" x-cloak @click="addToCart()" x-show="threshold <= 0" class="border font-medium text-lg py-3 px-6 bg-black text-white border-black w-full text-center block rounded-md">
                          {{ section.settings.footer_checkout_text }}
                      </button>
                  {% endif %}

                  {% if section.settings.checkout_behavior == 'checkout' %}
                      <button type="button" x-cloak @click="checkout(); $refs.checkout_btn_text.textContent = 'checking out'" 
                        x-show="threshold <= 0" 
                        class="border font-medium text-lg py-3 px-6 bg-black text-white border-black w-full text-center rounded-md flex justify-center items-center hover:bg-white hover:text-black hover:border-black transition-all duration-300">
                          <svg x-show="loadingCheckout" class="animate-spin -ml-1 mr-3 h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                          </svg>
                          <span x-ref="checkout_btn_text">
                              {{ section.settings.footer_checkout_text }}
                          </span>
                      </button>
                  {% endif %}
                  <template x-if="formError != ''">
                      <div class="text-red-500 text-center font-medium mt-2" x-text="formError"></div>
                  </template>
              </div>

          </div>
      </div>

      <div class="view__product fixed inset-0 bg-black/20 flex items-center justify-center z-[100]" x-trap="viewProductModal" tabindex="-1" role="dialog" x-cloak x-show="viewProductModal" aria-modal="true" aria-labelledby="product_view">
          <div class="w-[330px] md:w-[730px] lg:w-[830px] p-4 bg-white rounded-md relative" @click.outside="viewProductModal = false">
              <div class="absolute top-3 right-3 bg-white rounded-full flex items-center justify-center">
                  <button @click="viewProductModal = false" type="button" aria-label="Close modal" x-ref="close_modal" class="text-gray-500 hover:text-gray-700 focus:text-gray-700">
                      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon icon-close"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                  </button>
              </div>

              <div class="grid grid-col-1 md:grid-cols-2 max-h-[550px] md:max-[initial] overflow-scroll">

                  <div class="image__wrap md:mr-4">
                      <img :src="activeProduct.img" :alt="activeProduct.title" class="w-full" />
                  </div>
                  <div class="content">
                      <h3 x-text="activeProduct.title" id="product_view" class="text-2xl font-semibold mr-6 mb-4">View product</h3>

                      <div x-html="activeProduct.review" class="py-1 text-gray-600"></div>
                      <div x-html="activeProduct.details" class="py-3 text-gray-600 prose"></div>

                      <div class="shipping-wrapper pb-3 text-sm rounded-md mb-3 font-bold">
                            <p>Free U.S. Shipping Over $40, and a risk-free guarantee!</p>
                      </div>

                      <button @click="addToBag(activeProduct.id,activeProduct.title,activeProduct.img, activeProduct.price)"  class="button button--primary font-semibold" type="button">add to bundle</button>
                  </div>
              </div>
          </div>
      </div>
  </div>

</div>


