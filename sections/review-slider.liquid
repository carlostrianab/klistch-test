
<style>
  .section__title--{{ section.id }}{
    font-size: {{ section.settings.font_size  | append: 'px' }};
    color: {{ section.settings.text_color }}
  }
  #section-{{ section.id }} .stars svg{
    fill: {{ section.settings.star_color }} !important;
    stroke: {{ section.settings.star_color }} !important;
  }

  #section-{{ section.id }} .classic__design{
    border-color: {{ section.settings.border_color }} !important;
  }
  
  @media (max-width: 640px) {
    .section__title--{{ section.id }}{
      font-size: {{ section.settings.font_size_mobile | append: 'px' }};
    } 
  }
</style>

{% if section.settings.slider %}
  {% assign slider = true %}
{% endif %}
<div 
    id="section-{{ section.id }}"
    style="background-color: {{ section.settings.bg_color }}; 
          padding-top: {{ section.settings.padding_top }}px;
          padding-bottom: {{ section.settings.padding_bottom }}px;">
    <div class=" {{ section.settings.container }} mx-auto px-6">
      
        {% if section.settings.pre_title != blank %}
          <div class="pre-title {{ section.settings.align_text }} text-lg mb-3">
            {{ section.settings.pre_title }}
          </div>
        {% endif %}

        {% if section.settings.title != blank %}
          <h2 class="section__title--{{ section.id }} {{ section.settings.align_text }} font--secondary mb-6">
            {{ section.settings.title }}
          </h2>
        {% endif %}

        {% if section.settings.details != blank %}
            <div class="details text-center">
                {{ section.settings.details }}
            </div>
        {% endif %}
        
        <div class="relative overflow-x-hidden slider-wrap"
          {% if slider %}
            @keydown.right="next"
            @keydown.left="prev"
            tabindex="0"
            x-init="slider = $refs.slider"
            role="region"
            aria-labelledby="product carousel"
            x-data="carousel"
          {% endif %} 
            >
              {% if slider %}
                <button 
                    x-init="console.log($refs.slider.scrollLeft)"
                    @click="prev" 
                    class="prev-next w-10 h-10 rounded-full flex items-center justify-center p-1 absolute top-1/2 transform -translate-y-1/2 z-10 left-0">
                    {% render 'icon-arrow-left', class: 'w-8' %}
                    <span class="sr-only">Skip to previous slide</span>
                </button>
              {% endif %}
                    <div class=" 
                        {% if slider %} 
                          flex w-full  overflow-x-scroll no-scrollbar 
                        {% else %} 
                          grid 
                          {{ section.settings.grid_mobile }} 
                          {{ section.settings.grid_tablet }} 
                          {{ section.settings.grid }}
                        {% endif %}
                        {{ section.settings.grid_gap }}
                          md:pb-8 mx-auto"
                        {% if slider %}
                          x-ref="slider"
                          style="scroll-snap-type: x mandatory;"
                          role="list"
                        {% endif %}
                          >
                        {% for block in section.blocks %}
                            {% assign options = block.settings %}
                                <div 
                                {% if slider %}
                                  role="listitem" 
                                {% endif %}
                                  class="
                                    {% if section.settings.classic %}
                                      border-2 rounded-md classic__design
                                    {% endif %}
                                    {% if slider %}
                                      {{ section.settings.items_per_row_mobile }} 
                                      {{ section.settings.items_per_row_tablet }} 
                                      {{ section.settings.items_per_row }}
                                    {% else %}
                                      w-full
                                    {% endif %}
                                    flex-shrink-0 p-4 md:px-3">
                                    <div class="testimonial">
                                        {% if options.photo != blank %}
                                            <div class="testimonial__photo w-5/12 {{ block.settings.align_text }} rounded-full border-4 border-white">
                                                {{ options.photo | image_url: width: 400 | image_tag: loading: true, class: 'w-full object-cover' }}
                                            </div>
                                        {% endif %}

                                        <div class="px-4 {{ block.settings.align_text }}">
                                        
                                            {% if block.settings.show_stars %}
                                                <div class="stars">
                                                    {% render 'icon-stars' %}
                                                </div>
                                            {% endif %}

                                            {% if options.name != blank %}
                                                <h3 class="icon__name font-bold mt-3" style="color: {{ section.settings.text_color }}; font-size: {{ section.settings.title_font_size }}px; ">{{ options.name }}</h3>
                                            {% endif %}
    
                                            {% if options.subtitle != blank %}
                                                <div class="icon__subtitle" 
                                                    style="color: {{ section.settings.text_color }}; ">{{ options.subtitle }}
                                                </div>
                                            {% endif %}

                                            {% if options.text != blank %}
                                                <div class="icon__text text-base mt-4" style="color: {{ section.settings.text_color }}">
                                                    {{ options.text }}
                                                </div>
                                            {% endif %}


                                            {% if options.author != blank %}
                                                <h3 class="icon__author font-bold mt-3" style="color: {{ section.settings.text_color }}; font-size: {{ section.settings.title_font_size }}px; ">{{ options.author }}</h3>
                                            {% endif %}
                                            
                                        </div>
                                    </div>
                                </div>
                        {% endfor %}
                    </div>
                {% if slider %}
                  <button 
                      @click="next" 
                      class="prev-next w-10 h-10  rounded-full flex items-center justify-center p-1 absolute top-1/2 transform -translate-y-1/2 z-10 right-0">
                      {% render 'icon-arrow-right', class: 'w-8' %}
                      <span class="sr-only">Skip to next slide</span>
                  </button>
                {% endif %}

        </div>

    </div>
</div>

{% schema %}
