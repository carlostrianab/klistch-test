<style type="text/css">
  .password-logo {
    max-width: {{ section.settings.logo_max_width }}px;
  }
  .password-header-section{
    background-color: {{ section.settings.background_color }};
  }
</style>

<div class="password-header-section ">
  <div class="{{ section.settings.container }} mx-auto px-4">
    <div class="password-header flex justify-between py-6">
      {%- if section.settings.logo != blank -%}
        {%- assign logo_alt = section.settings.logo.alt | default: shop.name | escape -%}
        {%- assign logo_height = section.settings.logo_max_width | divided_by: section.settings.logo.aspect_ratio -%}
        {{ section.settings.logo | image_url: width: section.settings.logo.width | image_tag:
          class: 'password-logo object-contain ',
          widths: '50, 100, 150, 200, 250, 300, 400, 500',
          width: section.settings.logo_max_width,
          height: logo_height,
          alt: logo_alt
        }}
      {%- else -%}
        <h1 class="h2">{{ shop.name }}</h1>
      {%- endif -%}
  
      {%- if shop.password_message != blank -%}
        <div class="password-content">
          {{ shop.password_message }}
        </div>
      {%- endif -%}
  
      <div x-data="{ showModal: $persist(false), }">
        <button class="flex gap-x-2 px-4 py-2 is-focusable" type="button" @click="showModal = true">
          {% render 'icon-padlock', class: 'w-4' %}
          {{ 'general.password_page.login_password_button' | t }}
        </button>
        <!-- Password modal -->
        <div class="password__modal modal fixed inset-0 flex items-center justify-center bg-white z-20" 
          id="passwordModal" 
          x-transition 
          x-cloak
          x-show="showModal" 
          x-trap="showModal"
          tabindex="-1" role="dialog" aria-labelledby="passwordModalLabel" aria-hidden="true">
          <div class="modal-dialog" role="document">
            <!-- close button -->
            <button class="modal-close absolute top-6 right-6 px-4 py-2  is-focusable" type="button" @click="showModal = false">
              {% render 'icon-close', class: 'w-6' %}
            </button>
            <div class="modal-body">
                <h2 class="password-modal__content-heading mb-3 text-center" id="DialogHeading">
                  {{ 'general.password_page.login_form_heading' | t }}
                </h2>
                {%- form 'storefront_password', class: 'password-form' -%}
                  <div class="form__group flex gap-x-4">
                    <div class="password-field{% if form.errors %} password-field--error{% endif %}">
                      <input
                        type="password"
                        name="password"
                        id="Password"
                        class="form__input"
                        autocomplete="current-password"
                        {% if form.errors %}
                          aria-invalid="true"
                          aria-describedby="PasswordLoginForm-password-error"
                        {%- endif -%}
                        placeholder="{{ 'general.password_page.login_form_password_placeholder' | t }}"
                      >
                      <label class="form__input sr-only" for="{{ 'general.password_page.login_form_password_label' | t }}">{{ 'general.password_page.login_form_password_placeholder' | t }}</label>
                      {%- if form.errors -%}
                        <div id="PasswordLoginForm-password-error" role="status" class="my-3 text-sm">
                          <span class="sr-only">{{ 'accessibility.error' | t }}</span>
                          <span class="form__message flex gap-x-2">
                            {% render 'icon-error', class: 'w-6' %} 
                            {{ 'general.password_page.login_form_error' | t }}</span>
                        </div>
                      {%- endif -%}
                    </div>
                    <button name="commit" class="password-button button button--secondary is-focusable">
                      {{ 'general.password_page.login_form_submit' | t }}
                    </button>
                  </div>
                {%- endform -%}
                <small class="password__footer-text text-sm my-3 block text-center">{{ 'general.password_page.admin_link_html' | t }}</small>
            </div>
          </div>
        </div>
  
      </div>
  
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Password header",
  "settings": [
    {
      "type": "select",
      "id": "container",
      "options": [
        {
          "value": "full-width",
          "label": "Full Width"
        },
        {
          "value": "container",
          "label": "Container"
        },
        {
          "value": "page-width",
          "label": "Page Width"
        },
        {
          "value": "large-width",
          "label": "Large Width"
        },
        {
          "value": "medium-width",
          "label": "Medium Width"
        },
        {
          "value": "small-width",
          "label": "Small Width"
        }
      ],
      "default": "page-width",
      "label": "Container"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "range",
      "id": "logo_max_width",
      "min": 50,
      "max": 250,
      "step": 10,
      "default": 100,
      "unit": "px",
      "label": "Custom logo max width"
    },
    {
      "type": "header",
      "content": "Section styles"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color"
    }
  ]
}
{% endschema %}
