<style>
  #Featured-blog-{{ section.id }}{
      padding-top: {{ section.settings.padding_top | append: 'px' }};
      padding-bottom: {{ section.settings.padding_bottom | append: 'px' }};
  }
</style>

<div id="Featured-blog-{{ section.id }}" class="blog {{ section.settings.container }} mx-auto px-4  {% if section.settings.enable_swipe_mobile %} mobile-pr-0 {% endif %}">
    {%- unless section.settings.heading == blank -%}
      <div class="my-6">
        {% render 'heading', options: section.settings, id: section.id %}
      </div>
    {%- endunless -%}

    <div class="relative overflow-x-hidden">
      <ul class="gap-3 md:gap-4
        {% if section.settings.enable_swipe_mobile %}
          flex w-full overflow-x-scroll snap-mandatory snap-x no-scrollbar md:grid 
        {% else %}
          grid 
        {% endif %} 
        {{ section.settings.grid_desktop }} 
        {{ section.settings.grid_tablet }} 
        {{ section.settings.grid_mobile }}" role="list" style="scroll-snap-type: x mandatory;">

        {% if section.settings.blog != blank and section.settings.blog.articles_count > 0 %}
          {%- for article in section.settings.blog.articles limit: section.settings.post_limit -%}
            <li class="featured-colection__item {% if section.settings.enable_swipe_mobile %} w-10/12 md:w-full flex-shrink-0 snap-center last:mr-4 {% endif %}" {{ block.shopify_attributes }}>
              {%- render 'article-card',
                  article: article,
                  show_image: section.settings.show_image,
                  show_date: section.settings.show_date,
                  show_author: section.settings.show_author,
                  media_aspect_ratio: section.settings.image_ratio,
                  show_excerpt: true 
                -%}
            </li>
          {%- endfor -%}
        {% else %}
          {%- for i in (1..section.settings.post_limit) -%}
              <li class="featured-colection__item {% if section.settings.enable_swipe_mobile %} w-10/12 md:w-full flex-shrink-0 snap-center last:mr-4 {% endif %}">
                {%- render 'article-card', media_aspect_ratio: section.settings.image_ratio, show_excerpt: true 
                -%}
              </li>
          {%- endfor -%}
        {% endif %}
      </ul>

      {%- if section.settings.blog != blank and section.settings.show_view_all -%}
        <div class="flex items-center {{ section.settings.view_all_align }}">
          <a href="{{ section.settings.blog.url }}" class="button button--white max-w-fit !font-semibold mx-auto mt-5 ">
            {{ 'sections.featured_blog.view_all' | t }}
          </a>
        </div>
      {%- endif -%}
    </div>


  </div>

