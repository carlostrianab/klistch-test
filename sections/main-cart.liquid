
<style>
  #Main-cart-{{ section.id }}{
      padding-top: {{ section.settings.padding_top | append: 'px' }};
      padding-bottom: {{ section.settings.padding_bottom | append: 'px' }};
  }
</style>

<template data-options>
  {
    "item_count": {{ cart.item_count | json }},
    "cart_total": {{ cart.total_price | json }}
  }
</template>

<div id="Main-cart-{{ section.id }}" 
    @update-cart.window="updateCart()"
    x-title="{{ 'sections.cart.title' | t }}"
    x-data="Cart({{ cart | json | escape }}, '{{ section.id }}')"
    class="{{ section.settings.container }} mx-auto px-4">
    <div id="cart-page-content" x-ref="cart_content">
      {% render 'cart-drawer-form', context: 'cart-page' %}
    </div>
</div>

{% schema %}
{
  "name": "Main cart",
  "settings": [
    {
      "type": "select",
      "id": "container",
      "options": [
        {
          "value": "full-width",
          "label": "Full Width"
        },
        {
          "value": "container",
          "label": "Container"
        },
        {
          "value": "page-width",
          "label": "Page Width"
        },
        {
          "value": "large-width",
          "label": "Large Width"
        },
        {
          "value": "medium-width",
          "label": "Medium Width"
        },
        {
          "value": "small-width",
          "label": "Small Width"
        }
      ],
      "default": "page-width",
      "label": "Container"
    },
    {
      "type": "select",
      "id": "cart_page_layout",
      "options": [
        {
          "value": "fullwidth",
          "label": "Full width"
        },
        {
          "value": "sidebar",
          "label": "Sidebar"
        }
      ],
      "default": "sidebar",
      "label": "Cart layout"
    },
    {
      "type": "header",
      "content": "Heading styles"
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Text align",
      "default": "md:text-left",
      "options": [
        {
          "value": "md:text-left",
          "label": "Left"
        },
        {
          "value": "md:text-center",
          "label": "Center"
        },
        {
          "value": "md:text-right",
          "label": "Right"
        }
      ]
    },
    {
      "type": "select",
      "id": "font",
      "label": "Font family",
      "default": "font-heading",
      "options": [
        {
          "value": "font-primary",
          "label": "Primary"
        },
        {
          "value": "font-secondary",
          "label": "Secondary"
        },
        {
          "value": "font-heading",
          "label": "Heading"
        }
      ]
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Font weight",
      "default": "font-medium",
      "options": [
        {
          "value": "font-bold",
          "label": "Bold"
        },
        {
          "value": "font-semibold",
          "label": "Semibold"
        },
        {
          "value": "font-medium",
          "label": "Medium"
        },
        {
          "value": "font-normal",
          "label": "Normal"
        }
      ]
    },
    {
      "type": "header",
      "content": "Header styles (Mobile)"
    },
    {
      "type": "select",
      "id": "text_align_mobile",
      "label": "Text align",
      "default": "text-left",
      "options": [
        {
          "value": "text-center",
          "label": "Center"
        },
        {
          "value": "text-left",
          "label": "Left"
        },
        {
          "value": "text-right",
          "label": "Right"
        }
      ]
    },
    {
      "type": "header",
      "content": "Section styles"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "unit": "px",
      "min": 0,
      "max": 160,
      "step": 2,
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "unit": "px",
      "min": 0,
      "max": 160,
      "step": 2,
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "checkout_button",
      "name": "Checkout button",
      "limit": 1
    },
    {
      "type": "subtotal",
      "name": "Subtotal",
      "limit": 1
    },
    {
      "type": "savings",
      "name": "Savings",
      "limit": 1
    },
    {
      "type": "discount",
      "name": "Discount",
      "limit": 1
    },
    {
      "type": "cart_note",
      "name": "Cart note",
      "limit": 1
    },
    {
      "type": "express_checkout",
      "name": "Express checkout",
      "limit": 1
    },
    {
      "type": "continue_shopping",
      "name": "Continue shopping",
      "limit": 1,
      "settings": [
        {
          "type": "url",
          "id": "continue_shopping_url",
          "label": "Continue shopping link",
          "default": "/collections/all"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Main cart",
      "blocks": [

      ]
    }
  ],
  "templates": ["cart"]
}
{% endschema %}
