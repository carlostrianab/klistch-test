        "default": "md:text-left",
        "options": [
          {
            "value": "md:text-left",
            "label": "Left"
          }, {
            "value": "md:text-center",
            "label": "Center"
          }, {
            "value": "md:text-right",
            "label": "Right"
          }
        ]
      }, {
        "type": "select",
        "id": "font",
        "label": "Font family",
