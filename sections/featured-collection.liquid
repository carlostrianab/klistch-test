<style>
  #Featured-collection-{{ section.id }} {
    padding-top: {{ section.settings.padding_top | append: 'px' }};
    padding-bottom: {{ section.settings.padding_bottom | append: 'px' }};
  }
</style>
<div id="Featured-collection-{{ section.id }}" class="featured__collection {{ section.settings.container }} mx-auto px-4 {% if section.settings.enable_swipe_mobile %} mobile-pr-0 {% endif %}">
  <div class="featured__collection-wrapper">

    {%- unless section.settings.heading == blank -%}
      <div class="my-6">
        {% render 'heading'
          , options: section.settings
          , id: section.id %}
      </div>
    {%- endunless -%}

    <div class="relative overflow-x-hidden">
      <ul
        class="gap-3 md:gap-4
        {% if section.settings.enable_swipe_mobile %}
          flex w-full overflow-x-scroll snap-mandatory snap-x no-scrollbar md:grid 
        {% else %}
          grid 
        {% endif %} 
        {{ section.settings.grid_desktop }} 
        {{ section.settings.grid_tablet }} 
        {{ section.settings.grid_mobile }}"
        role="list"
        style="scroll-snap-type: x mandatory;">

        {% if section.settings.collection != blank %}
          {%- for product in section.settings.collection.products limit: section.settings.products_to_show -%}
            {% unless product.tags contains 'excluded_product' %}
              <li class="featured-colection__item {% if section.settings.enable_swipe_mobile %} w-10/12 md:w-full flex-shrink-0 snap-center last:mr-4 {% endif %}" {{ block.shopify_attributes }}>
                {% render 'card-product'
                  , card_product: product
                  , show_secondary_image: section.settings.show_secondary_image
                  , show_vendor: section.settings.show_vendor
                  , show_rating: section.settings.show_rating
                  , image_ratio: section.settings.image_ratio
                  , show_sold_count: section.settings.show_sold_count
                  , show_add_to_cart: section.settings.show_add_to_cart
                %}
              </li>
            {% endunless %}
          {%- endfor -%}
        {% else %}
          {%- for i in (1..section.settings.products_to_show) -%}
            {% unless product.tags contains 'excluded_product' %}
              <li class="featured-colection__item {% if section.settings.enable_swipe_mobile %} w-10/12 md:w-full flex-shrink-0 snap-center last:mr-4 {% endif %}">
                {% render 'card-product'
                  , show_vendor: section.settings.show_vendor %}
              </li>
            {% endunless %}

          {%- endfor -%}
        {% endif %}

      </ul>
    </div>

    {%- if section.settings.show_view_all -%}
      <div class="">
        <a href="{{ routes.collections_url }}" class="button button--white max-w-fit !font-semibold mx-auto mt-5">{{ 'sections.collection_list.view_all' | t }}</a>
      </div>
    {%- endif -%}
  </div>
</div>
{% schema %}
  {
    "name": "Featured collection",
    "tag": "section",
    "settings": [
      {
        "type": "select",
        "id": "container",
        "options": [
          {
            "value": "full-width",
            "label": "Full Width"
          },
          {
            "value": "container",
            "label": "Container"
          },
          {
            "value": "page-width",
            "label": "Page Width"
          },
          {
            "value": "large-width",
            "label": "Large Width"
          }, {
            "value": "medium-width",
            "label": "Medium Width"
          }, {
            "value": "small-width",
            "label": "Small Width"
          }
        ],
        "default": "page-width",
        "label": "Container"
      },
      {
        "type": "text",
        "id": "heading",
        "default": "Featured collection",
        "label": "Heading"
      },
      {
        "type": "richtext",
        "id": "sub_heading",
        "label": "Sub heading"
      },
      {
        "type": "text",
        "id": "heading_label",
        "label": "Label",
        "info": "This text will show above the heading as a label"
      }, {
        "type": "collection",
        "id": "collection",
        "label": "Collection"
      }, {
        "type": "range",
        "id": "products_to_show",
        "min": 2,
        "max": 16,
        "step": 2,
        "default": 4,
        "label": "Maximum products to show"
      }, {
        "type": "checkbox",
        "id": "show_view_all",
        "default": false,
        "label": "Enable View all",
        "info": "Show if list includes more collections than shown"
      }, {
        "type": "header",
        "content": "Product card"
      }, {
        "type": "select",
        "id": "image_ratio",
        "label": "Image ratio",
        "options": [
          {
            "value": "aspect-auto",
            "label": "Auto"
          }, {
            "value": "aspect-square",
            "label": "Square"
          }, {
            "value": "aspect-portrait",
            "label": "Portrait"
          }
        ]
      }, {
        "type": "checkbox",
        "id": "show_secondary_image",
        "default": false,
        "label": "Show second image on hover"
      }, {
        "type": "checkbox",
        "id": "show_vendor",
        "default": false,
        "label": "Show vendor"
      }, {
        "type": "checkbox",
        "id": "show_add_to_cart",
        "default": false,
        "label": "Show add to cart button"
      }, {
        "type": "checkbox",
        "id": "show_sold_count",
        "default": false,
        "label": "Show product sold count"
      }, {
        "type": "checkbox",
        "id": "show_rating",
        "default": false,
        "label": "Show product rating",
        "info": "To display a rating, add a product rating app. [Learn more](https://help.shopify.com/manual/online-store/themes/theme-structure/theme-features#featured-collection-show-product-rating)"
      }, {
        "type": "header",
        "content": "Grid layout"
      }, {
        "type": "select",
        "id": "grid_desktop",
        "label": "Desktop grid",
        "info": "Number of items per row",
        "default": "lg:grid-cols-5",
        "options": [
          {
            "value": "lg:grid-cols-1",
            "label": "1 item"
          },
          {
            "value": "lg:grid-cols-2",
            "label": "2 items"
          },
          {
            "value": "lg:grid-cols-3",
            "label": "3 items"
          },
          {
            "value": "lg:grid-cols-4",
            "label": "4 items"
          }, {
            "value": "lg:grid-cols-5",
            "label": "5 items"
          }, {
            "value": "lg:grid-cols-6",
            "label": "6 items"
          }
        ]
      }, {
        "type": "select",
        "id": "grid_tablet",
        "label": "Tablet grid",
        "info": "Number of items per row",
        "default": "md:grid-cols-3",
        "options": [
          {
            "value": "md:grid-cols-1",
            "label": "1 item"
          },
          {
            "value": "md:grid-cols-2",
            "label": "2 items"
          },
          {
            "value": "md:grid-cols-3",
            "label": "3 items"
          },
          {
            "value": "md:grid-cols-4",
            "label": "4 items"
          }, {
            "value": "md:grid-cols-5",
            "label": "5 items"
          }
        ]
      }, {
        "type": "select",
        "id": "grid_mobile",
        "label": "Mobile grid",
        "info": "Number of items per row",
        "default": "grid-cols-2",
        "options": [
          {
            "value": "grid-cols-1",
            "label": "1 item"
          }, {
            "value": "grid-cols-2",
            "label": "2 items"
          }, {
            "value": "grid-cols-3",
            "label": "3 items"
          }, {
            "value": "grid-cols-4",
            "label": "4 items"
          }
        ]
      }, {
        "type": "checkbox",
        "id": "enable_swipe_mobile",
        "label": "Enable swipe on mobile",
        "default": false
      }, {
        "type": "header",
        "content": "Heading styles"
      }, {
        "type": "range",
