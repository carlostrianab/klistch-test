<style>
  #contact-form-{{ section.id }}{
      padding-top: {{ section.settings.padding_top | append: 'px' }};
      padding-bottom: {{ section.settings.padding_bottom | append: 'px' }};
  }
</style>

<div id="contact-form-{{ section.id }}" class="contact__form py-3">
  <div class="{{ section.settings.container }} mx-auto px-4">
    
      {% if section.blocks.size > 0 %}
        <div class="w-full">
          {% form 'contact', class: 'contact-form' %}
            {% if form.posted_successfully? %}
              <div class="py-2">
                <p class="text-green-700 font-medium">{{ 'templates.contact.form.post_success' | t }}</p>
              </div>
            {% endif %}

            {% if form.errors %}
              <div class="py-2 contact-form__form-errors">
                <p class="quote">{{ 'templates.forms.post_error' | t }}</p>
                  {% assign message = 'templates.contact.form.message' | t %}
                  {% for field in form.errors %}
                    {% if field == 'form' %}
                      <p class="form__error text-red-600">
                        {{ form.errors.messages[field] }}
                      </p>
                    {% else %}
                      <p class="form__error text-red-600">
                        {% assign field_name = field | replace: 'body', message %}
                        {{ 'templates.forms.post_field_error_html' | t: field: field_name, error: form.errors.messages[field] }}
                      </p>
                    {% endif %}
                  {% endfor %}
              </div>
            {% endif %}

            <div class="contact-form__blocks space-y-3 py-4">
                {% for block in section.blocks %}
                    <div class="contact-form__block contact-form__block--{{ block.type }}" {{ block.shopify_attributes }}>
                      {% if block.type == 'textfield' %}
                      {% comment %} Text field {% endcomment %}
                        {% if block.settings.label != blank %}
                          {% assign label = block.settings.label %}
                        {% else %}
                          {% assign label = 'Option ' | append: forloop.index %}
                        {% endif %}

                        <div class="form-group flex flex-col">
                          <label for="{{ label | replace: ' ', '_' }}" class="form__label mb-2 {% if settings.use_placeholders %}sr-only{% endif %}">
                            {{ label }} {% if block.settings.required %}<span class="required">*</span>{% endif %}
                          </label>
                          <input type="text" placeholder="{% if settings.use_placeholders %}{{ label }}{% if block.settings.required %}*{% endif %}{% endif %}" 
                          name="contact[{{ label | replace: ' ', '_' }}]" id="{{ label | replace: ' ', '_' }}" 
                          class="form__input" {% if block.settings.required %}required="required"{% endif %} />
                        </div>

                      {% elsif block.type == 'dropdown' %}
                      {% comment %} Dropdown {% endcomment %}
                        <div class="input-group flex flex-col">
                          <label for="{{ block.settings.label | replace: ' ', '_' }}" class="form__label mb-2 {% if settings.use_placeholders %}sr-only{% endif %}">
                            {{ block.settings.label }} {% if block.settings.required %}<span class="required">*</span>{% endif %}
                          </label>
  
                          <select class="form__input" name="contact[{{ block.settings.label | replace: ' ', '_' }}]" {% if block.settings.required %}required="required"{% endif %}>
                            {% if settings.use_placeholders %}
                              <option value="" selected disabled>{{ block.settings.label }} {% if block.settings.required %}<span class="required">*</span>{% endif %}</option>
                            {% endif %}
                            {% for index in (0..10) %}
                              {%- capture option -%}options_{{ index }} {%- endcapture -%}
                              {% if forloop.index0 == 0 %}
                                {% if block.settings.placeholder != blank %}
                                  <option value="">
                                    {{ block.settings.placeholder }}
                                  </option>
                                {% endif %}
                              {% else %}
                                {% if block.settings[option] != blank %}
                                  <option value="{{ block.settings[option] }}">
                                    {{ block.settings[option] }}
                                  </option>
                                {% endif %}
                              {% endif %}
                            {% endfor %}
                          </select>

                        </div>

                      {% elsif block.type == 'radio' %}
                      {% comment %} Radio {% endcomment %}

                        {% if block.settings.label != blank %}
                          {% assign label = block.settings.label %}
                        {% else %}
                          {% assign label = 'Option ' | append: forloop.index %}
                        {% endif %}

                        <div class="input-group flex flex-col">
                            <label class="label form__label mb-2">
                              {{ label }} {% if block.settings.required %}<span class="required">*</span>{% endif %}
                            </label>
    
                            <ul class="contact-form__list">
                              {% for index in (1..10) %}
                                {%- capture option -%}options_{{ index }}{%- endcapture -%}
                                {% if block.settings[option] != blank %}
                                  <li class="flex items-center space-x-2">
                                    <input type="radio" id="{{ block.settings[option] | handleize }}" class="radio" name="contact[{{ label }}]" value="{{ block.settings[option] }}" {% if forloop.first %}checked{% endif %}/>
                                    <label for="{{ block.settings[option] | handleize }}">
                                      {{ block.settings[option] }}
                                    </label>
                                  </li>
                                {% endif %}
                              {% endfor %}
                            </ul>
                        </div>

                      {% elsif block.type == 'checkbox' %}
                      {% comment %} Checkbox {% endcomment %}

                        
                        {% if block.settings.label != blank %}
                          {% assign label = block.settings.label %}
                        {% else %}
                          {% assign label = 'Option ' | append: forloop.index %}
                        {% endif %}
                        <div class="input-group flex flex-col">
                          <label class="form__label mb-2">
                            {{ label }} {% if block.settings.required %}<span class="required">*</span>{% endif %}
                          </label>
                          <ul class="contact-form__list" {% if block.settings.required %}data-is-required{% endif %}>
                            {% for index in (1..10) %}
                              {%- capture option -%}options_{{ index }}{%- endcapture -%}
                              {% if block.settings[option] != blank %}
                                <li class="flex items-center space-x-2">
                                  <input type="checkbox" id="checkbox[option{{ index }}]" class="checkbox" name="contact[{{ label }}]" value="{{ block.settings[option] }}"/>
                                  <label for="checkbox[option{{ index }}]">
                                    {{ block.settings[option] }}
                                  </label>
                                </li>
                              {% endif %}
                            {% endfor %}
                          </ul>
                        </div>

                      {% elsif block.type == 'textarea' %}
                      {% comment %} Textarea {% endcomment %}
                        <div class="input-group flex flex-col">
                            <label for="textarea{{ forloop.index }}" class="form__label mb-2 {% if settings.use_placeholders %}sr-only{% endif %}">
                              {{ block.settings.label }} {% if block.settings.required %}<span class="required">*</span>{% endif %}
                            </label>
    
                            <textarea placeholder="{% if settings.use_placeholders %}{{ block.settings.label }}{% if block.settings.required %}*{% endif %}{% endif %}" id="textarea{{ forloop.index }}" 
                              class="form__textarea" name="contact[body]" {% if block.settings.required %}required="required"{% endif %}></textarea>
                        </div>

                      {%- elsif block.type == 'heading' -%}
                        {% liquid render 'heading', options: block.settings, id: block.id %}

                      {%- elsif block.type == 'text' -%}
                        {% liquid render 'text', block: block  %}

                      {% elsif block.type == 'email' %}
                      {% comment %} Email {% endcomment %}

                        {% if block.settings.label != blank %}
                          {% assign label = block.settings.label %}
                        {% else %}
                          {% assign label = 'Option ' | append: forloop.index %}
                        {% endif %}
                        <div class="input-group flex flex-col">
                          <label for="contactFormEmail" class="form__label mb-2 {% if settings.use_placeholders %}sr-only{% endif %}">
                            {{ label }} <span class="required">*</span>
                          </label>
  
                          <input type="email" placeholder="{% if settings.use_placeholders %}{{ label }}*{% if block.settings.required %}*{% endif %}{% endif %}" id="contactFormEmail" class="form__input" 
                          name="contact[email]" autocorrect="off" autocapitalize="off" value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}" required="required">

                        </div>

                      {% elsif block.type == 'submit' %}
                        <button type="submit" class="button button--secondary">
                          {{ block.settings.label }}
                        </button>
                      {% endif %}
                    </div>
                {% endfor %}
            </div>
            <input type="hidden" name="challenge" value="false" />
           
          {% endform %}
        </div>
      {% endif %}
   
  </div>
</div>

