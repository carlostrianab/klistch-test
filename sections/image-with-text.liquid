<style>
  #Image-with-text-{{ section.id }}{
      background-color: {{ section.settings.background_color }};
      color: {{ section.settings.text_color }};
      padding-top: {{ section.settings.padding_top | append: 'px' }};
      padding-bottom: {{ section.settings.padding_bottom | append: 'px' }};
      margin-top: {{ section.settings.margin_top | append: 'px' }};
      margin-bottom: {{ section.settings.margin_bottom | append: 'px' }};
  }
</style>

<div id="Image-with-text-{{ section.id }}" class="image-with-text">
  <div class="{{ section.settings.container }} mx-auto px-4">
    <div 
      style="background-color: {{ section.settings.blocks_background_color }};"
      class="flex flex-col md:flex-row
      {% unless section.settings.image_first %} md:flex-row-reverse {% endunless %}
      {{ section.settings.vertical_alignment }} 
      {{ section.settings.vertical_alignment_mobile }}
      ">
      <div class="image-with-text__media w-full md:w-1/2 relative bg-no-repeat bg-cover 
        {% if section.settings.image_padding %} py-6 {% endif %} 
        {{ section.settings.image_overlap_mobile }} {{ section.settings.image_overlap }}">
        {% if section.settings.image != blank or section.settings.video_url != blank %}
          {% if section.settings.image_link != blank %}
            <a href="{{ section.settings.image_link }}" class="block" aria-label="{{ section.settings.image_mobile.alt |  default: 'Kitsch image links'  }}"> 
          {% endif %}

            {% assign img_class = ' h-full object-cover ' %}
            {% if section.settings.image_mobile != blank %} 
              {% assign img_class = img_class | append: ' hidden md:block ' %}
            {% endif %}

            {% if section.settings.image != blank and section.settings.video_url == blank  %}
              {% render 'picture', image: section.settings.image, preload: section.settings.preload class: img_class %}
            {% endif %}
            
            {% assign img_class = ' md:hidden ' %}
            {% if section.settings.image_mobile != blank and section.settings.video_url_mobile == blank %}
              {% render 'picture-mobile', image: section.settings.image_mobile, preload: section.settings.preload class: img_class %}
            {% endif %}

            {% if section.settings.video_url != blank %}
              <div class="banner__media relative {% if section.settings.video_url_mobile != blank %} hidden md:block {% endif %}"
                {% unless section.settings.desktop_height == 100 %}
                style="height: {{ section.settings.desktop_height | append: 'px'  }}" 
                {% endunless %} 
                x-data="{ playing: {{ section.settings.autoplay }}, muted: true }">
                {{ section.settings.video_url | media_tag: image_size: "1200x", autoplay: section.settings.autoplay , loop: section.settings.loop, controls: section.settings.controls, preload: "none", class: "w-full h-full object-cover", muted: true, loading: "lazy", x-ref: "video" }}
                {% if section.settings.custom_controls %}
                    {% render '_video-custom-controls' %}
                {% endif %}
              </div>
            {% endif %}
        
            {% if section.settings.video_url_mobile != blank %}
              <div class="banner__media relative md:hidden" 
                x-data="{ playing: {{ section.settings.autoplay }}, muted: true }">
                {{ section.settings.video_url_mobile | media_tag: image_size: "700x", autoplay: section.settings.autoplay , loop: section.settings.loop, controls: section.settings.controls, preload: "none", class: "w-full h-full object-cover", muted: true, loading: "lazy", x-ref: "video" }}
                {% if section.settings.custom_controls %}
                  {% render '_video-custom-controls' %}
                {% endif %}
              </div>
            {% endif %}


          {% if section.settings.image_link != blank %}
            </a>
          {% endif %}

        {% else %}
          {{ 'image' | placeholder_svg_tag }}
        {% endif %}
      </div>
  
      <div class="image-with-text__content flex h-full w-full md:w-1/2 {{ section.settings.horizontal_alignment }} {{ section.settings.horizontal_alignment_mobile }}">
          <div style="color: {{ section.settings.text_color }}; max-width: {{ section.settings.content_max_width }}px;"
            class="image-with-text__box p-4">
            {%- for block in section.blocks -%}
              {%- case block.type -%}
                {%- when 'custom_liquid' -%}
                 {% if block.settings.custom_liquid != blank %}
                  <div id="Custom_liquid_{{ block.id }}">
                    {{ block.settings.custom_liquid }}
                  </div>
                 {% endif %}
                {%- when 'heading' -%}
                  {%- render 'heading', options: block.settings, id: block.id -%}
                {%- when 'text' -%}
                  {% render 'text', block: block %}
                {%- when 'buttons' -%}
                  {% render 'buttons', block: block %}
              {%- endcase -%}
            {%- endfor -%}
          </div>
      </div>

    </div>
  </div>
</div>

