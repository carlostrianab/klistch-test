<style>
  #Accordions-{{ section.id }}{
    background-color: {{ section.settings.background_color }};
    color: {{ section.settings.text_color }};
    padding-top: {{ section.settings.padding_top | append: 'px' }};
    padding-bottom: {{ section.settings.padding_bottom | append: 'px' }};
    margin-top: {{ section.settings.margin_top | append: 'px' }};
    margin-bottom: {{ section.settings.margin_bottom | append: 'px' }};
  }
  #Accordions-{{ section.id }} .prose{
    background-color: {{ section.settings.background_color }};
    color: {{ section.settings.text_color }};
  }
</style>

<div id="Accordions-{{ section.id }}" class="accordions">
  <div class="accordions__wrapper {{ section.settings.container }} mx-auto px-4">
    {%- unless section.settings.heading == blank -%}
      <div class="my-6">
        {% render 'heading', options: section.settings, id: section.id %}
      </div>
    {%- endunless -%}

    <div class="relative mt-8">
      <ul class="grid
        {{ section.settings.grid_desktop }} 
        {{ section.settings.grid_tablet }} 
        {{ section.settings.grid_mobile }} border-t border-black" role="list">
        {% for block in section.blocks %}
          <li>
            {% if block.type == 'accordion' %}
              {% if block.settings.title != blank %}
                {% render 'accordion-item-block', options: block.settings, index: forloop.index %}
              {% endif %}
            {% endif %}
          </li>
        {% endfor %}
      
      </ul>
    </div>

  </div>
</div>

