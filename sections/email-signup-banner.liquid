
<style>
    #EmailSignupBanner-{{ section.id }}{
        height: {{ section.settings.desktop_height | append: 'px' }};
    }
    @media screen and (max-width: 749px) {
        #EmailSignupBanner-{{ section.id }}{
          height: {{ section.settings.mobile_height | append: 'px' }};
        }
    }
</style>
<div id="EmailSignupBanner-{{ section.id }}" class="email-signup-banner relative overflow-hidden {{ section.settings.container }} mx-auto px-4">
  {%- if section.settings.show_background_image -%}
    <div class="banner__media {% if section.settings.image != blank %} media{% endif %} h-full">
      {%- if section.settings.image != blank -%}
        <div class="banner__media h-full {% if section.settings.image_mobile != blank %} hidden md:block  {% endif %}">
          {% render 'img-large', image: section.settings.image, class: 'w-full object-cover ' %}
        </div>
      {%- else -%}
        {%- render 'email-signup-banner-background', class: ' object-fit w-full h-full' -%}
      {%- endif -%}

      {%- if section.settings.image_mobile != blank -%}
        <div class="banner__media md:hidden h-full">
          {% render 'img-mobile', image: section.settings.image_mobile, class: 'w-full h-full object-cover' %}
        </div>
      {%- endif -%}

    </div>
  {%- endif -%}

  <div class="absolute inset-0">
    <div class="banner__content inset-0 flex h-full {{ section.settings.vertical_alignment }} 
    {{ section.settings.horizontal_alignment }}
    {{ section.settings.vertical_alignment_mobile }}
    {{ section.settings.horizontal_alignment_mobile }}">
      <div style="
        max-width: {{ section.settings.max_width }}px;
        background-color: rgba({{ section.settings.content_background.red }}, {{ section.settings.content_background.green }}, {{ section.settings.content_background.blue }}, {{ section.settings.content_background_opacity }}); 
        color: {{ section.settings.text_color }};" class="banner__box py-4 px-8 space-y-4 rounded-md w-full mx-4">
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'heading' -%}
              {%- render 'heading', options: block.settings, id: block.id -%}
            {%- when 'text' -%}
              {% render 'text', block: block %}
            {%- when 'email_form' -%}
              <div {{ block.shopify_attributes }}>
                {% form 'customer', class: 'newsletter-form' %}
                  <input type="hidden" name="contact[tags]" value="newsletter">
                  <div class="newsletter-form__field-wrapper">
                    <div class="input__group flex gap-x-2 {{ block.settings.mobile_alignment }} {{ block.settings.desktop_alignment }}">
                      <input
                        id="NewsletterForm--{{ section.id }}"
                        type="email"
                        name="contact[email]"
                        class="form__input w-full"
                        value="{{ form.email }}"
                        aria-required="true"
                        autocorrect="off"
                        autocapitalize="off"
                        autocomplete="email"
                        {% if form.errors %}
                          autofocus
                          aria-invalid="true"
                          aria-describedby="Newsletter-error--{{ section.id }}"
                        {% elsif form.posted_successfully? %}
                          aria-describedby="Newsletter-success--{{ section.id }}"
                        {% endif %}
                        placeholder="{{ 'newsletter.label' | t }}"
                        required
                      >
                      <label class="form__label sr-only" for="NewsletterForm--{{ section.id }}">
                        {{ 'newsletter.label' | t }}
                      </label>
                      
                      <button type="submit" class="newsletter-form__button button button--secondary is-focusable" name="commit" id="Subscribe" aria-label="{{ 'newsletter.button_label' | t }}">
                        {{ 'newsletter.button_label' | t }}
                      </button>
                    </div>
                    {%- if form.errors -%}
                      <small class="newsletter-form__message flex gap-2 my-2 text-sm" id="ContactFooter-error">
                        {% render 'icon-error', class: 'w-4' %}
                        {{ form.errors.translated_fields['email'] | capitalize }} {{ form.errors.messages['email'] }}
                      </small>
                    {%- endif -%}

                  </div>
                  {%- if form.posted_successfully? -%}
                    <h3 class="newsletter-form__message flex gap-2 my-2 text-sm" id="ContactFooter-success" tabindex="-1" autofocus>
                      {% render 'icon-success', class: 'w-4' %}
                      {{ 'newsletter.success' | t }}
                    </h3>
                  {%- endif -%}
                {% endform %}
              </div>
          {%- endcase -%}
        {%- endfor -%}
      </div>
    </div>
  </div>

</div>
