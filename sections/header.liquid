    },
    {
      "type": "text",
      "id": "extra2_link",
      "label": "Link"
    },
    {
      "type": "image_picker",
      "id": "extra2_icon",
      "label": "Image"
    },
    {
      "type": "header",
      "content": "icon 3"
    },
    {
      "type": "text",
      "id": "extra3_title",
      "label": "Title"
    },
    {
      "type": "text",
      "id": "extra3_link",
      "label": "Link"
    },
    {
      "type": "image_picker",
      "id": "extra3_icon",
      "label": "Image"
    },
    {
      "type": "header",
      "content": "icon 4"
    },
    {
      "type": "text",
      "id": "extra4_title",
      "label": "Title"
    },
    {
      "type": "text",
      "id": "extra4_link",
      "label": "Link"
    },
    {
      "type": "image_picker",
      "id": "extra4_icon",
      "label": "Image"
    },
    {
      "type": "header",
      "content": "Section styles"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#424242"
    },
    {
      "type": "color",
      "id": "sales_color",
      "label": "Sales color",
      "info": "Leave blank to use the default color"
    },
    {
