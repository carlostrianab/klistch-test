<!-- Klaviyo event -->
<script type="text/javascript">
  var _learnq = _learnq || [];
  var item = {
    Name: {{ product.title|json }},
    ProductID: {{ product.id|json }},
    Categories: {{ product.collections|map:'title'|json }},
    ImageURL: "https:{{ product.featured_image.src|img_url:'grande' }}",
    URL: "{{ shop.secure_url }}{{ product.url }}",
    Brand: {{ product.vendor|json }},
    Price: {{ product.price|money|json }},
    CompareAtPrice: {{ product.compare_at_price_max|money|json }}
  };

  var newItem = {
    Name: {{ product.title|json }},
    ProductID: {{ product.id|json }},
    Categories: {{ product.collections|map:'title'|json }},
    ImageURL: "https:{{ product.featured_image.src|img_url:'grande' }}",
    URL: "{{ shop.secure_url }}{{ product.url }}",
    Brand: {{ product.vendor|json }},
    Price: {{ product.price | strip_html | money | json  }},
    CompareAtPrice: {{ product.compare_at_price_max | strip_html | money | json }}
  };

  _learnq.push(['track', 'Viewed Product', newItem]);
  _learnq.push(['trackViewedItem', {
    Title: newItem.Name,
    ItemId: newItem.ProductID,
    Categories: newItem.Categories,
    ImageUrl: newItem.ImageURL,
    Url: newItem.URL,
    Metadata: {
      Brand: newItem.Brand,
      Price: newItem.Price,
      CompareAtPrice: newItem.CompareAtPrice
    }
  }]);

  setTimeout(() => {
    
    const AddToCartButton = document.querySelectorAll('.button-add-to-cart');
    AddToCartButton.forEach(function(currentBtn){
      currentBtn.addEventListener('click', function(){
        //  _learnq.push(['track', 'Added to Cart', item]);
        console.log('newItem: ', newItem);
          _learnq.push(['track', 'Added to Cart', newItem]);
      })
    })

    // Twitter add to cart event
    AddToCartButton.forEach(function(currentBtn){
      currentBtn.addEventListener('click', function(){
        // Insert Twitter Event ID
        twq('event', 'tw-odgrs-odsd4', {
          value: {{ product.price | money_without_currency | json }} , // use this to pass the value of the conversion (e.g. 5.00)
          currency: {{ cart.currency.iso_code | json }}, // use this to pass the currency of the conversion with an ISO 4217 code (e.g. ‘USD’)
          contents: [ 
              {
                content_type: {{ product.type | json }},
                content_id: {{ product.id | json }},
                content_name: {{ product.title | json }},
                content_price: {{ product.price |  money_without_currency | json }}
              }], 
          {%if customer %}
            email_address: {{ customer.email | json }} // use this to pass a user’s email address
          {% endif %}
        });
      })
    })

  }, 1000);



</script>

<style>
  .product__info-wrapper .oke-sr{
    padding-top: 0 !important;
  }
</style>

<!-- Enavi Quick Shop test reviews anchor event -->
<script type="text/javascript">
  document.addEventListener('DOMContentLoaded', () => {
    if (window.location.search === '?anchor=reviews') {
      // Convert tracking for review click
      window._conv_q = window._conv_q || [];
      _conv_q.push(["triggerConversion", "100488977"]);
      // Wait for Okendo widget to load
      setTimeout(() => {
        const reviewWidget = document.querySelector('.shopify-app-block [data-oke-reviews-product-id]');
        if (reviewWidget) {
          reviewWidget.scrollIntoView({ behavior: 'smooth' });
        }
      }, 1000);
    }
  });
</script>

