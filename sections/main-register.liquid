<style>
  .register__page{
    padding-top: {{ settings.padding_top }}px;
    padding-bottom: {{ settings.padding_bottom }}px;
  }
</style>
<div class="register__page {{ section.settings.container }} mx-auto px-4">

  <div class="h-full my-6 md:my-8">
    <header class="flex items-center justify-center">
      <h2 class="text-3xl font-heading textx-center" tabindex="-1"> {{ 'customer.register.title' | t }}</h2>
    </header>

    <div class="flex items-center h-full">
      <div class="w-full">          
          {%- form 'create_customer', novalidate: 'novalidate' -%}
          
            {%- if form.errors -%}
              <div class="error__wrapper">
                <h4 class="flex text-base mb-2 items-center p-2" tabindex="-1" autofocus>
                  <span> {% render 'icon-error' %}</span>
                  {{ 'templates.contact.form.error_heading' | t }}
                </h4>

                <ul class="list-disc text-red-700 ml-8 mb-4"> 
                  {%- for field in form.errors -%}
                    <li>
                      {%- if field == 'form' -%}
                        {{ form.errors.messages[field] }}
                      {%- else -%}
                        <a href="#RegisterForm-{{ field }}">
                          {{ form.errors.translated_fields[field] | capitalize }}
                          {{ form.errors.messages[field] }}
                        </a>
                      {%- endif -%}
                    </li>
                  {%- endfor -%}
                </ul>

              </div>
            {%- endif -%}

            <div class="flex flex-col mb-3"> 
              <label for="RegisterForm-FirstName" class="form__label mb-2">
                {{ 'customer.register.first_name' | t }}
              </label>     
              <input
                type="text"
                name="customer[first_name]"
                id="RegisterForm-FirstName"
                placeholder="{{ 'customer.register.first_name' | t }}"
                class="form__input"
                {% if form.first_name %}value="{{ form.first_name }}"{% endif %}
                autocomplete="given-name"
              >
            
            </div>

            <div class="flex flex-col mb-3">
              <label for="RegisterForm-LastName" class="form__label mb-2">
                {{ 'customer.register.last_name' | t }}
              </label>
              <input
                type="text"
                name="customer[last_name]"
                id="RegisterForm-LastName"
                placeholder="{{ 'customer.register.last_name' | t }}"
                {% if form.last_name %}value="{{ form.last_name }}"{% endif %}
                autocomplete="family-name"
                class="form__input"
              >
            
            </div>

            <div class="flex flex-col mb-3">
              <label for="RegisterForm-email" class="form__label mb-2">
                {{ 'customer.register.email' | t }}
              </label>  
              <input
                type="email"
                name="customer[email]"
                id="RegisterForm-email"
                placeholder="{{ 'customer.register.email' | t }}"
                {% if form.email %} value="{{ form.email }}"{% endif %}
                spellcheck="false"
                autocapitalize="off"
                autocomplete="email"
                aria-required="true"
                class="form__input"
                {% if form.errors contains 'email' %}
                  aria-invalid="true"
                  aria-describedby="RegisterForm-email-error"
                {% endif %}
              >

              {%- if form.errors contains 'email' -%}
                <span id="RegisterForm-email-error" class="form__message flex items-center space-x-2 text-sm pt-2">
                  {% render 'icon-error', class: 'w-4 mr-1' %}
                  {{ form.errors.translated_fields['email'] | capitalize }} {{ form.errors.messages['email'] }}.
                </span>
              {%- endif -%}
            
            </div>
        
            <div class="flex flex-col mb-6"> 
              <label for="RegisterForm-password" class="form__label mb-2">
                {{ 'customer.register.password' | t }}
              </label>    
              <input
                type="password"
                name="customer[password]"
                id="RegisterForm-password"
                aria-required="true"
                placeholder="{{ 'customer.register.password' | t }}"
                class="form__input"
                {% if form.errors contains 'password' %}
                  aria-invalid="true"
                  aria-describedby="RegisterForm-password-error"
                {% endif %}
              >
              {%- if form.errors contains 'password' -%}
                <span id="RegisterForm-password-error" class="form__message flex items-center space-x-2 text-sm pt-2">
                  {% render 'icon-error', class: 'w-4 mr-1' %}
                  {{ form.errors.translated_fields['password'] | capitalize }} {{ form.errors.messages['password'] }}.
                </span>
              {%- endif -%}

            </div>

            <div class="flex items-center space-x-6 my-3">
              <button class="button button--secondary">
                {{ 'customer.register.submit' | t }}
              </button>
              <a href="{{ routes.account_login_url }}" class="text-center underline">
                {{ 'customer.login_page.cancel' | t }}
              </a>
            </div>
            
        {%- endform -%}

      </div>
    </div>
  </div>

</div>


{% schema %}
{
  "name": "Register page",
  "settings": [
    {
      "type": "select",
      "id": "container",
      "options": [
        {
          "value": "full-width",
          "label": "Full Width"
        },
        {
          "value": "container",
          "label": "Container"
        },
        {
          "value": "page-width",
          "label": "Page Width"
        },
        {
          "value": "large-width",
          "label": "Large Width"
        },
        {
          "value": "medium-width",
          "label": "Medium Width"
        },
        {
          "value": "small-width",
          "label": "Small Width"
        }
      ],
      "default": "small-width",
      "label": "Container"
    },
    {
      "type": "header",
      "content": "Styles"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 36
    }
  ]
}
{% endschema %}
