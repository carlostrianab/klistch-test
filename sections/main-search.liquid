
{%- liquid
  assign sort_by = search.sort_by | default: search.default_sort_by
  assign terms = search.terms | escape
  assign search_url = '?q=' | append: terms | append: '&options%5Bprefix%5D=last&sort_by=' | append: sort_by
-%}

<style>
  #SearchTemplate{
    padding-top: {{ section.settings.padding_top | append: 'px' }};
    padding-bottom: {{ section.settings.padding_bottom | append: 'px' }};
  }
</style>

<div id="SearchTemplate" class="{{ section.settings.container }} mx-auto px-4">
  <div class="template-search__header">
      <h1 class="text-xl md:text-3xl font-heading text-center">
        {%- if search.performed -%}
          {{ 'templates.search.title' | t }}
        {%- else -%}
          {{ 'general.search.search' | t }}
        {%- endif -%}
      </h1>

    <div class="template-search__search {{ section.settings.search_size }} mx-auto">
        <form action="{{ routes.search_url }}" 
          {% if settings.predictive_search_enabled %}
            x-data="Search(`{{ search.terms | escape }}`, {{ settings.predictive_search_limit }})"
          {% endif %}
          method="get" role="search" class="search mt-8">
          <div class="flex flex-col md:flex-row gap-2">
            <div class="relative w-full" @click.outside="showSearch = false">
              <input
                class="form__input w-full "
                id="Search-In-Template"
                type="search"
                name="q"
                value="{{ search.terms | escape }}"
                aria-label="{{ 'general.search.search' | t }}"
                placeholder="{{ 'general.search.search' | t }}"
                {%- if settings.predictive_search_enabled -%}
                  x-model="query"
                  @focus.debounce="performSearch(); showSearch = true"
                  @input.debounce="performSearch()"
                  role="combobox"
                  aria-expanded="false"
                  aria-owns="predictive-search-results-list"
                  aria-controls="predictive-search-results-list"
                  aria-haspopup="listbox"
                  aria-autocomplete="list"
                  autocorrect="off"
                  autocomplete="off"
                  autocapitalize="off"
                  spellcheck="false"
                {%- endif -%}>
              <label class="sr-only" for="Search-In-Template">{{ 'general.search.search' | t }}</label>
              <input name="options[prefix]" type="hidden" value="last">

              <div class="predictive__search border border-t-transparent -mt-1 rounded-b absolute w-full bg-white z-50" x-cloak x-collapse x-show="showSearch">
                  <h3 class="text-gray-600 border-b p-3 uppercase text-xs" x-show="products.length > 0">{{ 'general.search.products' | t }}</h3>
                  <div class="relative">
                    {% render 'inline-loader' %}
                    <template x-if="products.length > 0">
                      <ul class="predictive__search-products px-3 flex flex-col" role="list">
                        <template x-for="item in products">
                            <li class="products__item py-2 border-b my-2">
                              <a :href="item.url" class="flex gap-x-3 items-center">
                                <div class="products__item-image w-20">
                                  <img :src="item.image" loading="lazy" class="object-cover" :alt="item.title">
                                </div>
                              
                                <div class="products__item-info flex flex-col">
                                  {% if settings.predictive_search_show_vendor %}
                                    <span class="prdoucts__item-vendor text-xs uppercase text-gray-500" x-text="item.vendor"></span>
                                  {% endif %}
                                  <span class="products__item-name-text hover:underline" x-text="item.title"></span>
                                  {% if settings.predictive_search_show_price %}
                                    <span class="prdoucts__item-price text-sm text-gray-500" x-text="Unick.formatMoney2(item.price)"></span>
                                  {% endif %}
                                </div>
                                
                              </a>
                          </li>
                        </template>
                      </ul>
                      
                    </template>
                  </div>

                  <button type="submit" x-show="query != ''" 
                    class="px-4 py-2 bg-gray-100 flex justify-between text-sm items-center w-full" 
                    aria-label="{{ 'general.search.button' | t }}">
                    <span class="flex items-center gap-1"> 
                        <i>{% render 'icon-magic2', class: 'w-5 h-5' %}</i>
                        {{ 'general.search.search_for' | t }} "<i x-text="query"></i>" 
                    </span>
                    <span> {% render 'icon-arrow-right' %} </span>
                  </button>

              </div>
            </div>
            <button type="submit" class="search__button button button--secondary" aria-label="{{ 'general.search.search' | t }}">
              {{ 'general.search.button' | t }}
            </button>
          </div>
          {% assign query = search.terms | append: '"' | prepend: '"' %}
          <div class="text-center py-5">
            {{ 'general.search.result' | t: query: query, count: search.results.size }}
          </div>
        </form>
    </div>
  </div>
  
  {%- if search.performed -%}
      <div class="product-grid-container my-6" id="ProductGridContainer">
        {%- if search.results.size == 0 and search.filters != empty -%}
          <div class="template-search__results collection collection--empty{% if section.settings.filter_type != 'vertical' %} page-width{% endif %}" id="product-grid" data-id="{{ section.id }}">
            <div class="loading-overlay gradient"></div>
            <div class="title-wrapper center">
              <h2 class="title title--primary">
                {{ 'sections.collection_template.empty' | t }}<br>
                {{ 'sections.collection_template.use_fewer_filters_html' | t: link: search_url, class: "underlined-link link" }}
              </h2>
            </div>
          </div>
        {%- else -%}
          {% paginate search.results by section.settings.products_per_page %}
            <div class="template-search__results" id="item-grid" data-id="{{ section.id }}">
              <ul class="grid
                {{ section.settings.gap }}
                {{ section.settings.gap_mobile }} 
                {{ section.settings.grid_desktop }} 
                {{ section.settings.grid_tablet }} 
                {{ section.settings.grid_mobile }}">
                {%- for item in search.results -%}
                  <li class="grid__item">
                    {%- case item.object_type -%}
                      {%- when 'product' -%}
                        {% render 'card-product',
                          card_product: item,
                          show_secondary_image: section.settings.show_secondary_image,
                          show_vendor: section.settings.show_vendor,
                          show_rating: section.settings.show_rating,
                          show_sold_count: section.settings.show_sold_count,
                          image_ratio: section.settings.image_ratio

                        %}
                      {%- when 'article' -%}
                        {% render 'article-card',
                          article: item,
                          show_image: true,
                          show_date: section.settings.article_show_date,
                          show_author: section.settings.article_show_author,
                          show_badge: true,
                          media_aspect_ratio: section.settings.image_ratio
                        %}
                      {%- when 'page' -%}
                        <div class="card p-2 h-full bg-gray-100 relative">
                          <div class="card__content h-full flex items-center justify-center text-center">
                            <div class="card__information">
                              <h3 class="card__heading">
                                <a href="{{ item.url }}" class="text-base">
                                  {{ item.title | truncate: 50 | escape }}
                                </a>
                              </h3>
                            </div>
                            <div class="card__badge absolute top-2 right-2 bg-white rounded-md px-3 py-1 text-sm border">
                              <span class="badge">{{ 'templates.search.page' | t }}</span>
                            </div>
                          </div>
                        </div>
                    {%- endcase -%}
                  </li>
                {%- endfor -%}
              </ul>

              {%- if paginate.pages > 1 -%}
                {% render 'pagination', paginate: paginate %}
              {%- endif -%}
            </div>
          {% endpaginate %}
        {%- endif -%}
      </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Search results",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "select",
      "id": "container",
      "options": [
        {
          "value": "full-width",
          "label": "Full Width"
        },
        {
          "value": "container",
          "label": "Container"
        },
        {
          "value": "page-width",
          "label": "Page Width"
        },
        {
          "value": "large-width",
          "label": "Large Width"
        },
        {
          "value": "medium-width",
          "label": "Medium Width"
        },
        {
          "value": "small-width",
          "label": "Small Width"
        }
      ],
      "default": "page-width",
      "label": "Container"
    },
    {
      "type": "range",
      "id": "products_per_page",
      "min": 8,
      "max": 32,
      "step": 1,
      "default": 16,
      "label": "Products per page"
