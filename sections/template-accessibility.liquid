<section class="accessibility-section {{ section.settings.container }} mx-auto px-4">
        <div class="border-b">
            <div class="page-width">
                <ul class="sub-menu flex text-xl">
                    <li class="sub-menu-item w-1/2">
                       <a href="#{{ section.settings.menu_1 }}" class="py-4 block" title="{{ section.settings.menu_1 }}"> {{ section.settings.menu_1 }} </a>
                    </li>
                    <li class="sub-menu-item w-1/2">
                        <a href="#{{ section.settings.menu_2 }}" class="py-4 block" title="{{ section.settings.menu_2 }}"> {{ section.settings.menu_2 }} </a>
                    </li>
                </ul>
            </div>
        </div>

        <div class="content-wrapper page-width pt-4">
            {% for block in section.blocks %}
                {% if forloop.first == true %}
                    <div id="{{ section.settings.menu_1 }}" class="sroll-to"></div>
                {% else %}
                <div id="{{ section.settings.menu_2 }}" class="sroll-to"></div>
                {% endif %}
                <div class="content md:flex mb-6 md:mb-12">

                    <div class="left-content md:w-1/3">
                        <p class="label-dash py-2"> 0 {{ forloop.index }} 
                            <hr class="w-8 bg-black border-black"/>
                        </p>
                        <h4 class="mt-3 text-3xl"> {{ block.settings.title }} </h4>
                    </div>
                    <div class="right-content md:w-2/3">
                        <p class="label-dash  hidden md:block">&nbsp;
                            <hr class="w-8 bg-black border-black hidden md:block"/>
                        </p>
                        <div class="main-right-content mt-3">
                            <h5 class="text-xl mb-2"> {{ block.settings.content_title }} </h5>
                            {{ block.settings.content_description }}
                        </div>
                    </div>
                </div> 
            {% endfor %}
        </div>

</section>


{% schema %}
{
    "name": "Accessibility",
    "max_blocks": 2,
    "settings": [
        {
            "type": "select",
            "id": "container",
            "options": [
                {
                "value": "full-width",
                "label": "Full Width"
                },
                {
                "value": "container",
                "label": "Container"
                },
                {
                "value": "page-width",
                "label": "Page Width"
                },
                {
                "value": "large-width",
                "label": "Large Width"
                },
                {
                "value": "medium-width",
                "label": "Medium Width"
                },
                {
                "value": "small-width",
                "label": "Small Width"
                }
            ],
            "default": "page-width",
            "label": "Container"
        },
        {
        "type": "header",
        "content": "Sub Menu"
        },
        {
        "type": "text",
        "id": "menu_1",
        "default": "Menu 1",
        "label": "Sub Menu 1"
        },  
        {
        "type": "text",
        "id": "menu_2",
        "default": "Menu 2",
        "label": "Sub Menu 2"
        },  
        {
        "type": "image_picker",
        "id": "accessibility_logo",
        "label": "Logo"
        }
    ],
    "blocks": [
    {
      "name": "Accessibilty content",
      "type": "content",
      "settings": [
        {
            "type": "header",
            "content": "Title"
        },  
        {
            "type": "text",
            "id": "title",
            "label": "Title here",
            "default": "STATEMENT"
        },
        {
            "type": "header",
            "content": "Content"
        },
        {
          "type": "text",
          "id": "content_title",
          "label": "Content title here",
          "default": " ACCESSIBILITY STATEMENT"
        },
        {
          "type": "richtext",
          "id": "content_description",
          "label": "Content here"
        }
    ]}
    ]
}
{% endschema %}