        | remove: '"https:\/\/cdn.getcarro.com\/script-tags\/all\/050820094100.js?shop=kitschllc.myshopify.com"'
        | remove: '"https:\/\/cdn.getcarro.com\/script-tags\/all\/nb-101920173500.js?shop=kitschllc.myshopify.com"'
      }}
    {% else %}
      {{
        h_content
        | remove: 'https:\/\/cdn.getcarro.com\/script-tags\/all\/cro-pixel-bundle.js?event_key=8be8299b-f9ce-4297-a133-2e785c45c087\u0026shop=kitschllc.myshopify.com'
        | remove: '"\/\/searchserverapi.com\/widgets\/shopify\/init.js?a=4J1Y4r9x5n\u0026shop=kitschllc.myshopify.com",'
        | remove: '"\/\/searchserverapi.com\/widgets\/shopify\/init.js?a=4J1Y4r9x5n\u0026shop=kitschllc.myshopify.com",'
        | remove: '"https:\/\/d275fvz7g8rvo.cloudfront.net\/kitschllc.myshopify.com\/online_store_script.js?shop=kitschllc.myshopify.com",'
        | remove: '"https:\/\/cdn.getcarro.com\/script-tags\/all\/050820094100.js?shop=kitschllc.myshopify.com"'
        | remove: '"https:\/\/cdn.getcarro.com\/script-tags\/all\/nb-101920173500.js?shop=kitschllc.myshopify.com"'
      }}
