    {% render 'theme-head-styles' %}
    {% render 'theme-head-scripts' %}
    {{ 'app.css' | asset_url | stylesheet_tag }}

    <script>
      document.documentElement.className = document.documentElement.className.replace('no-js', 'js');
      if (Shopify.designMode) {
        document.documentElement.classList.add('shopify-design-mode');
      }
    </script>
    <!-- Start of Wordsworth AI Script -->   
    <script defer src="https://d2zd0wa1vpt7j9.cloudfront.net/1f8659abc4c7529d/wwai_section_analytics.js"></script>
    <script defer src="https://d2zd0wa1vpt7j9.cloudfront.net/engagement_metrics_visualisation.js"></script>
    <!-- End of Wordsworth AI Script -->   

    {% if template.name == 'index' %}
      <script type="application/ld+json">
        {
          "@context": "http://schema.org",
          "@type": "WebSite",
          "name": "{{ shop.name }}",
          "potentialAction": {
            "@type": "SearchAction",
            "target": "{{ routes.search_url }}?q={search_term_string}",
            "query-input": "required name=search_term_string"
          },
          "url": "{{ shop.url }}{{ page.url }}"
        }
      </script>
    {% endif %}

    <!-- comment -->
    <dynamic>
      {% capture boostersnippet %}{% include "booster-apps-common" %}{% endcapture -%}
      {%- unless boostersnippet contains 'Liquid error' %}{{ boostersnippet }}{% endunless %}
    </dynamic>
    <!-- comment -->

    {% comment %} <script>
      document.addEventListener('DOMContentLoaded', () => {
        setTimeout(() => {
          if(!Unick.getCookie('discount_code')){
            Unick.setCookie('discount_code', 'LOVE25', 1);
            window.dispatchEvent(new CustomEvent('discount-applied'))
          }
        }, 1000)
      })
    </script> {% endcomment %}
  </head>

  <body class="gradient">
    <a class="skip-to-content-link button sr-only" href="#MainContent">
      {{ 'accessibility.skip_to_text' | t }}
    </a>

    {% liquid
      if settings.cart_type == 'drawer'
        render 'cart-drawer'
      endif

      if settings.quick_view_enabled
        render 'quick-view-drawer'
      endif
      sections 'header-group'

      render 'quick-view-bundle'
    %}

    <main id="MainContent" class="content-for-layout focus-none" role="main" tabindex="-1">
      {{ content_for_layout }}
    </main>

    {% comment %} {% section 'footer-trust' %} {% endcomment %}

    {% liquid
      render 'dynamic-modal'
      section 'footer'
      render 'pickup-availability-drawer'
      render 'json-ld'
    %}

    <ul hidden>
      <li id="a11y-refresh-page-message">{{ 'accessibility.refresh_page' | t }}</li>
      <li id="a11y-new-window-message">{{ 'accessibility.link_messages.new_window' | t }}</li>
    </ul>

    <script src="https://cdn.attn.tv/mykitsch/dtag.js" defer></script>
    {% render 'afterpay' %}
    {% render 'ship-scott-ab-test' %}

    <!-- This line added automatically by JSON-LD for SEO. -->
    {% include 'jsonld-for-seo' %}

    {% comment %}Loop returns onsite snippet - 11.20.23 {% endcomment %}
    <script src="https://cdn.jsdelivr.net/npm/@loophq/onstore-sdk@latest/dist/loop-onstore-sdk.min.js"></script>
    <script>
      LoopOnstore.init({
      key: "6395308e501fa4e607c1dcefb57023fdbc9893dd",
      attach: "#checkout_button_new",
      });
    </script>
  </body>
</html>
