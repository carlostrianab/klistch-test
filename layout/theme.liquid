    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="">
    <link rel="canonical" href="{{ canonical_url }}">
    <link rel="preconnect dns-prefetch" href="https://cdn.shopify.com" crossorigin>
    <link rel="preconnect dns-prefetch" href="https://fonts.shopifycdn.com" crossorigin>
    <link rel="preconnect dns-prefetch" href="https://v.shopify.com" crossorigin>
    <link rel="preconnect dns-prefetch" href="https://cdn.shopifycloud.com" crossorigin>

    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    <!-- LoudCrowd -->
    {% if request.path contains '/pages/shop' %}
      <link rel="preload" href="{{ 'loudcrowd.css' | asset_url }}" as="style">
      {{ 'loudcrowd.css' | asset_url | stylesheet_tag }}
    {% endif %}

    <title>
      {{ page_title }}
      {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
      {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
    </title>

    {% if page_description %}
      <meta name="description" content="{{ page_description | escape }}">
    {% endif %}

    {% render 'meta-tags' %}
    <script src="{{ 'app.js' | asset_url }}" defer></script>

    {% capture h_content %}
    	{{ content_for_header }}
    {% endcapture %}

    {% comment %} Remove octaneai from all other pages {% endcomment %}
    {% unless page.handle contains 'take-the-kitsch-quiz' %}
      {{
        h_content
        | remove: 'https:\/\/cdn.getcarro.com\/script-tags\/all\/cro-pixel-bundle.js?event_key=8be8299b-f9ce-4297-a133-2e785c45c087\u0026shop=kitschllc.myshopify.com'
        | remove: '"https:\/\/app.octaneai.com\/43m48tpugrhv7cwq\/shopify.js?x=xu42gwL5aaEhOnmd\u0026shop=kitschllc.myshopify.com",'
        | remove: '"\/\/searchserverapi.com\/widgets\/shopify\/init.js?a=4J1Y4r9x5n\u0026shop=kitschllc.myshopify.com",'
        | remove: '"\/\/searchserverapi.com\/widgets\/shopify\/init.js?a=4J1Y4r9x5n\u0026shop=kitschllc.myshopify.com",'
