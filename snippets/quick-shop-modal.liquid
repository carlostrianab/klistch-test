<div class="fixed inset-0 z-[110] h-full quick-shop-modal"
  x-data="QuickShop"
  x-cloak
  x-show="showQuickShop"
  @toggle-quick-shop.window="$nextTick(() => fetchProduct($event.detail.handle, $event.detail.isBundle, $event.detail.hasOptions))"
  @close-quick-shop.window="closeModal()"
  @keydown.escape.window="closeModal()"
  role="dialog" 
  aria-modal="true">
    
  <!-- Overlay -->
  <div class="fixed inset-0 bg-black/50" @click="closeModal()"></div>
  
  <!-- Modal -->
  <div class="absolute inset-0 m-auto max-h-[90vh] w-[90vw] bg-white"
      @click.outside="closeModal()"
      x-show="showQuickShop"
      x-transition:enter="transition ease-out duration-300"
      x-transition:enter-start="opacity-0 scale-95"
      x-transition:enter-end="opacity-100 scale-100"
      x-transition:leave="transition ease-in duration-200"
      x-transition:leave-start="opacity-100 scale-100"
      x-transition:leave-end="opacity-0 scale-95"
      style="max-width: 75rem;">
      
      <!-- Close Button -->
      <button type="button" 
          @click="closeModal()" 
          class="absolute top-0 right-0 p-2 z-10 bg-white"
          aria-label="{{ 'accessibility.close' | t }}">
          {% render 'icon-close', class: "w-5" %}
      </button>

      <!-- Loading State -->
      <div x-show="loading" class="absolute inset-0 flex items-center justify-center">
        <svg class="icon-spinner animate-spin w-6 text-black mr-2" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-50" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"></circle>
          <path class="opacity-100" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
        </svg>
      </div>

      <!-- Content -->
      <div class="quick-shop-content overflow-auto h-full" x-ref="quick_shop_content">
          <!-- Content loaded via AJAX -->
      </div>
  </div>
</div>

<style>

  .quick-shop-modal .quick-shop-content{
    min-height: 50vh;
  }
  .quick-shop-modal .product-form {
    display: flex;
    flex-direction: column;
  }

  .subscription-wrapper{
    order: 1;
  }

  .qs-quantity-selector {
    order: 2;
  }

  .qs-form-actions{
    order: 3;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .quick-shop-modal .afterpay-paragraph{
    justify-content: flex-start !important;
  }

  .quick-shop-modal .main-product{
    padding: 1.5rem;
  }

  .quick-shop-modal .breadcrumbs,
  .quick-shop-modal .accordion-item{
    display: none !important;
  }

  @media screen and (max-width: 768px) {
    .subscription-wrapper{
      order: 2;
    }
  
    .qs-quantity-selector {
      order: 1;
    }
  
    .qs-form-actions{
      order: 3;
      display: flex;
      flex-direction: row;
    }

    .qs-form-actions button{
      order: 2;
    }

    .qs-form-actions a{
      order: 1;
    }

    .quick-shop-content .discount-flag{
      left: .5rem !important;
      right: unset !important;
    }
  }
</style>