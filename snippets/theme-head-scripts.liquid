{% assign pageName = page.title %}
{% assign pageType = 'Page' %}
<!-- Twitter page view event -->
<script type="text/javascript">
  {% if template.name == 'product' %}
    {%  assign pageName = product.title %}
    {%  assign pageType = 'Product' %}
  {% endif %}
  {% if template.name == 'collection' %}
    {%  assign pageName = collection.title %}
    {%  assign pageType = 'Collection' %}
  {% endif %}
  {% if template.name == 'page' %}
    {%  assign pageName = page.title %}
    {%  assign pageType = 'Page' %}
  {% endif %}

  // Insert Twitter Event ID
  twq('event', 'tw-odgrs-odhc6', {
    contents: [ // use this to pass an array of products or content
        // add all items to the array
        // use this for the first item
        {
          content_type: {{ template.name | json }},
          content_name: {{ pageName | json }},
        }] 
  });
</script>
<!-- End Twitter conversion tracking event code -->

