{% if product != blank %}
{% capture product_data_attribute %}data-oke-reviews-product-id="shopify-{{ product.id }}"{% endcapture %}
{% endif %}

{% if product.metafields.okendo.summaryData.reviewCount > 0 %}
    <div class="flex items-center okendo-custom-review {% if settings.review_format == 'compact' or compact_reviews == true  %}justify-space-between {% else %}justify-center{% endif %} lg:justify-normal">
        <div data-oke-star-rating {{ product_data_attribute }}>
            {{ product.metafields.okendo.StarRatingSnippet }}
        </div>

        {% if settings.review_format == 'compact' or compact_reviews == true  %}
            {% assign review_count = product.metafields.okendo.summaryData.reviewCount %}
            {% assign k_count = review_count | divided_by: 1000 %}
            {% assign m_count = review_count | divided_by: 1000000 %}
            {% if review_count >= 1000000 %}
                {% assign m_count = m_count | round: 1 %}
                {% assign review_count = m_count | append: 'M+' %}
            {% elsif review_count >= 1000 %}
                {% assign k_count = k_count | round: 1 %}
                {% assign review_count = k_count | append: 'K+' %}
            {% endif %}
            <style>
                [data-oke-star-rating] .oke-sr-count{
                    display: none !important;
                }
                /* Mobile */
                @media (max-width: 767px) {
                    [data-oke-star-rating] .oke-stars-background svg,
                    [data-oke-star-rating] .oke-stars-foreground svg {
                        width: 60px;
                    }
                    .okendo-custom-review{
                        font-size: 14px;
                    }
                    [data-oke-star-rating] .oke-sr-stars{
                        margin-right: 2px;
                    }
                    .flex.items-center.okendo-custom-review{
                        gap: 2px;
                    }
  
                }

            </style>
            <span>
                {{ 'products.product.reviews_count' | t: count: review_count | split:'reviews' | first }} 
            </span>

        {% endif %}

    </div>
{% endif %}
