{%- if localization.available_countries.size > 1 -%}
    <noscript>
      {%- form 'localization', id: 'FooterCountryFormNoScript', class: 'localization-form' -%}
        <div class="localization-form__select">
          <p class="sr-only" id="FooterCountryLabelNoScript">{{ 'localization.country_label' | t }}</p>
          <select class="localization-selector link" name="country_code" aria-labelledby="FooterCountryLabelNoScript">
            {%- for country in localization.available_countries -%}
              <option value="{{ country.iso_code }}" {%- if country.iso_code == localization.country.iso_code %} selected{% endif %}>
                {{ country.name }} ({{ country.currency.iso_code }} {{ country.currency.symbol }})
              </option>
            {%- endfor -%}
          </select>
          {% render 'icon-caret' %}
        </div>
        <button class="button button--tertiary">{{ 'localization.update_country' | t }}</button>
      {%- endform -%}
    </noscript>
   
    {%- form 'localization', id: 'FooterCountryForm', class: 'localization-form my-4 border border-black' -%}
        <div class="no-js-hidden">
            <h2 class="sr-only" id="FooterCountryLabel">{{ 'localization.country_label' | t }}</h2>
            <div class="disclosure relative"
                x-title="{{ 'localization.country_label' | t }}"
                @click.outside="open = false"
                x-cloak
                x-init="$nextTick(() => { 
                    $watch('country', (value) => {
                        document.getElementById('FooterCountryForm').submit();
                    });
                    
                    // if url has country_code param, send a put request to update the country
                    if (window.location.search.includes('country_code')) {
                        // get country_code from url using new URLSearchParams
                        let urlParams = new URLSearchParams(window.location.search);
                        let country_code = urlParams.get('country_code');
                        console.log('dd:', country_code);

                        if (country_code && !Unick.getCookie('has_country')) {
                            country = country_code;
                            Unick.setCookie('has_country', true, 1);
                        }

                    }
                })"
                @change-location.window="$nextTick(() => {
                   let country_code = $event.detail.country;
                   console.log(country_code);
                   if (country_code) {
                       country = country_code;
                   }
                })"
                x-data="{
                    open: false,
                    country: '{{ localization.country.iso_code }}'
                }">
                <button type="button" @click="open = true" class="disclosure__button flex gap-x-2 px-2 py-1 border" aria-expanded="false" aria-controls="FooterCountryList" aria-describedby="FooterCountryLabel">
                    {{ localization.country.name }} ({{ localization.country.currency.iso_code }}{{ localization.country.currency.symbol }})
                    {% render 'icon-chevron-right', class: "h-5 transform rotate-90" %}

                </button>
                
                <div class="disclosure__list-wrapper absolute bottom-10 z-20 bg-white px-2 py-1 overflow-scroll max-h-72 text-black shadow-md border" x-show="open" x-transition.opacity>
                    <ul id="FooterCountryList" role="list" class="disclosure__list space-y-1">
                    {%- for country in localization.available_countries -%}
                        <li class="disclosure__item" tabindex="-1">
                            <button type="button" 
                                @click="country = '{{ country.iso_code }}'"
                                class="text-sm text-left {% if country.iso_code == localization.country.iso_code %} disclosure__link--active font-bold {% endif %}" 
                                {% if country.iso_code == localization.country.iso_code %} aria-current="true"{% endif %}>
                                {{ country.name }} <span class="localization-form__currency">({{ country.currency.iso_code }}{{ country.currency.symbol }})</span>
                            </button>
                        </li>
                    {%- endfor -%}
                    </ul>
                </div>
                
                <input type="hidden" name="country_code" x-model="country" value="{{ localization.country.iso_code }}">
            </div>
        </div>
    {%- endform -%}
   
  {%- endif -%}