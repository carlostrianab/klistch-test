<div class="fixed z-50 inset-0 overflow-y-auto" x-cloak x-show="openDelete" x-transition.opacity
        aria-modal="true"
        @keyup.escape="openDelete = false"
        x-trap="openDelete"
        aria-labelledby="deleteAddressTitle">
        <div class="flex items-end justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0">

            <div class="absolute inset-0 bg-black/20" x-show="openDelete" x-transition.opacity @click="openDelete = false; deleteId = null"></div>
            <!-- This element is to trick the browser into centering the modal contents. -->
            <span class="hidden sm:inline-block sm:align-middle sm:h-screen" aria-hidden="true">&#8203;</span>
            
            <div class="inline-block align-bottom bg-white text-left overflow-hidden shadow-xl transform transition-all sm:my-8 sm:align-middle sm:max-w-lg sm:w-full rounded-lg" role="dialog" aria-modal="true" aria-labelledby="{{ 'customer.addresses.add_new' | t }}">
                <div class="flex py-5 px-4">
                    <div class="mx-auto flex-shrink-0 flex items-center justify-center h-12 w-12 rounded-full bg-red-100 sm:mx-0 sm:h-10 sm:w-10">
                        {% render 'icon-alert', class: 'text-red-600' %}
                    </div>

                    <div class="mt-3 text-center sm:mt-0 sm:ml-4 sm:text-left">
                        <h3 class="text-lg leading-6 font-medium text-gray-900" id="deleteAddressTitle">
                            {{ 'customer.addresses.delete_title' | t }}
                        </h3>
                        <div class="mt-2 text-base">
                            <p class="font-medium">
                                {{ 'customer.addresses.delete_confirm' | t }}
                            </p>
                        </div>
                    </div>
                </div>
                <div class="px-4 py-3 sm:px-6 flex justify-end gap-4">
                    <button type="button" @click="openDelete = false; deleteId = null" class="underline text-sm px-4        ">
                        {{ 'customer.addresses.cancel' | t }}
                    </button>
                    
                    <form data-address-delete-form method="post" :action="'/account/addresses/'+deleteId" data-confirm-message="{{ 'customer.addresses.delete_confirm' | t }}">
                        <input type="hidden" name="_method" value="delete"/>
                        <button type="submit" class="button bg-red-600 text-white">
                            {{ 'customer.addresses.delete' | t }}
                        </button>
                    </form>

                </div>

            </div>
        </div>
</div>
