<div>
    <ul class="flex flex-col w-full text-base font-medium">
        <li class=""> 
            <a href="#rivo" 
                class="{% if request.path == '/account' %} font-bold text-black {% endif %}
                    flex flex-row items-center h-10">
                    <span class="flex items-center justify-center text-gray-800">
                        {% render 'icon-account' , class: 'w-7' %}
                    </span>
                <span class="ml-3">{{ 'customer.account.details' | t }}</span>
            </a>
        </li>    
        
        <li class="">
            <a href="{{ routes.account_addresses_url }}" 
                class="{% if request.path == '/account/addresses' %}  font-bold text-black {% endif %}
                flex flex-row items-center h-10">
                <span class="flex items-center justify-center text-gray-800">
                    {% render 'icon-map-pin' , class: 'w-7' %}
                </span>
                <span class="ml-3">{{ 'customer.account.view_addresses' | t }} ({{ customer.addresses_count }}) </span>
            </a>
        </li>
        
        <li class="">
            <a href="{{ routes.account_logout_url }}" 
                class="flex flex-row items-center h-10">
                <span class="flex items-center justify-center text-gray-800">
                    {% render 'icon-logout' , class: 'w-7' %}
                </span>
                <span class="ml-3">{{ 'customer.account.logout' | t }} </span>
            </a>
        </li>
    </ul>
</div>
<div class="text-sm">
    <div class="py-2">
        <h2 class="text-base pb-2 font-semibold">{{ customer.name }}</h2>
        {{ customer.email }}
    </div>
    <div class="py-2">
        <h2 class="text-base pb-2 font-semibold">{{ 'customer.addresses.default' | t }}</h2>
        {{ customer.default_address | format_address }}
    </div>
</div>