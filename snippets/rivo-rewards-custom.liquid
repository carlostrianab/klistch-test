
<div class="rivo-rewards-container" id="rivo-ways-to-redeem">
   <div class="rivo-lp-section-title">
      Use Your Beauty Points For Beauty Perks
    </div>
    <div class="rivo-lp-section-subtitle">
      Putting your routine first has its perks. Redeem points to restock your must-haves…<em>or to try something new</em>.
    </div>
  <div class="rivo-rewards-grid">
    <!-- Remove the template card, we'll handle everything in JS -->
  </div>
   
  {% if customer %}
    <div class="rivo-load-more-container">
      <button class="rivo-load-more" type="button" style="display: none;">
        Show more
      </button>
      <div class="rivo-items-count"></div>
    </div>
  {% endif %}
</div>


<!-- Add Login Modal HTML -->
<div class="rivo-login-modal-overlay" id="rivoLoginModal" role="dialog" aria-labelledby="loginModalTitle" aria-modal="true">
  <div class="rivo-login-modal-content">
    <button type="button" class="rivo-login-modal-close" aria-label="Close modal">×</button>
    <h2 class="rivo-login-modal-title">Join and Earn Rewards</h2>
    <p class="rivo-login-modal-subtitle">Earn points and turn these into rewards!</p>
    <a href="/account/register" class="rivo-login-modal-button">START EARNING</a>
    <div class="rivo-login-modal-signin">
      Already a member? <a href="/account/login" class="rivo-login-modal-link">Sign in</a>
    </div>
  </div>
</div>

<script type="text/javascript">
const RivoModal = {
  init: function() {
    this.injectModalHTML();
    
    // Cache DOM elements
    this.modal = document.getElementById('rivoRewardModal');
    this.closeButton = this.modal.querySelector('.rivo-modal-close');
    this.redeemButton = this.modal.querySelector('.rivo-modal-redeem');
    this.modalImage = this.modal.querySelector('.rivo-modal-image');
    
    // Cache button state elements
    this.buttonText = this.redeemButton.querySelector('.button-text');
    this.buttonSpinner = this.redeemButton.querySelector('.button-spinner');
    this.buttonSuccess = this.redeemButton.querySelector('.button-success');
    this.codeContainer = this.modal.querySelector('.rivo-redemption-code');
    
    // Cache the new placeholder element
    this.modalPlaceholder = this.modal.querySelector('.rivo-modal-placeholder');
    
    // Initialize selected product storage
    this.selectedProduct = null;
    
    this.isRedeeming = false; // Add redemption state flag
    
    this.bindEvents();
  },
  
  injectModalHTML: function() {
    const modalHTML = `
      <div class="rivo-modal-overlay" id="rivoRewardModal" role="dialog" aria-labelledby="modalTitle" aria-modal="true">
        <div class="rivo-modal-content">
          <header class="rivo-modal-header">
            <button type="button" class="rivo-modal-close" aria-label="Close modal">×</button>
          </header>
          
          <div class="rivo-modal-body">
            <div class="rivo-modal-product">
              <img class="rivo-modal-image" alt="">
              <div class="rivo-modal-placeholder" style="display: none;"></div>
              <div class="rivo-modal-product-details">
                <h3 class="rivo-modal-product-name"></h3>
                <p class="rivo-modal-points"></p>
                <div class="rivo-redemption-code" style="display: none;">
                  <input type="text" class="rivo-code-input" readonly>
                  <button type="button" class="rivo-copy-code" aria-label="Copy code">
                    <svg class="copy-icon" viewBox="0 0 24 24" width="24" height="24">
                      <path d="M16 1H4C3 1 2 2 2 3v14h2V3h12V1zm3 4H8C7 5 6 6 6 7v14c0 1 1 2 2 2h11c1 0 2-1 2-2V7c0-1-1-2-2-2zm0 16H8V7h11v14z"/>
                    </svg>
                  </button>
                </div>
              </div>
            </div>

            <button type="button" class="rivo-modal-redeem">
              <span class="button-text">Redeem</span>
              <span class="button-spinner" style="display: none;"></span>
              <span class="button-success" style="display: none;">✓</span>
            </button>
            
            <div class="rivo-modal-warning"></div>
          </div>
        </div>
      </div>
    `;
    
    if (!document.getElementById('rivoRewardModal')) {
      document.body.insertAdjacentHTML('beforeend', modalHTML);
    }
  },
  
  openModal: function(product, customerPoints) {
    this.selectedProduct = product;
    const hasEnoughPoints = customerPoints >= product.points_amount;

    this.modalImage.style.display = 'none';
    this.modalPlaceholder.style.display = 'flex';
    this.modalPlaceholder.textContent = product.name;
   
    // Use preloaded modal image if available
    const preloadedModalImage = RivoRewards.preloadedImages.get(`modal-${product.icon_url}`);
    if (preloadedModalImage) {
      this.modalImage.style.display = 'block';
      this.modalPlaceholder.style.display = 'none';
      this.modalImage.src = preloadedModalImage.src;
      // Use requestAnimationFrame for smooth transition
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          this.modalImage.style.opacity = '1';
        });
      });
    } else {
      this.modalImage.style.display = 'none';
      this.modalPlaceholder.style.display = 'flex';
      this.modalPlaceholder.textContent = product.name;
     }
    
    // Update other modal content
    this.modal.querySelector('.rivo-modal-image').alt = product.name;
    this.modal.querySelector('.rivo-modal-product-name').textContent = product.name;
    this.modal.querySelector('.rivo-modal-points').textContent = `${product.pretty_points_amount} Points`;
    
    // Update redeem button state
    this.redeemButton.disabled = !hasEnoughPoints;
    this.buttonText.textContent = hasEnoughPoints ? 'Redeem' : 'Not enough points';
    this.redeemButton.classList.toggle('insufficient-points', !hasEnoughPoints);

  if (product.terms_of_service.show_tos == true) {
    const termsOfService = product.pretty_terms_of_service.replace('<br/>', '');
    const warningElement = this.modal.querySelector('.rivo-modal-warning');
    warningElement.textContent = `${termsOfService}`;
    warningElement.style.display = 'block';  // Make sure to show the element
    } else {
    this.modal.querySelector('.rivo-modal-warning').style.display = 'none';
    }
    
    // Show modal
    this.modal.classList.add('is-active');
    document.body.classList.add('modal-open');
    
    // Focus management
    this.lastFocusedElement = document.activeElement;
    this.closeButton.focus();
  },
  
  closeModal: function() {
    this.modal.classList.remove('is-active');
    document.body.classList.remove('modal-open');
    this.modalImage.src = '';
    
    // Reset modal states
    this.buttonText.style.display = 'inline-block';
    this.buttonText.textContent = 'Redeem';
    this.buttonSpinner.style.display = 'none';
    this.buttonSuccess.style.display = 'none';
    this.redeemButton.disabled = false;
    this.redeemButton.classList.remove('insufficient-points');
    
    // Hide and clear redemption code
    this.codeContainer.style.display = 'none';
    const codeInput = this.modal.querySelector('.rivo-code-input');
    if (codeInput) {
      codeInput.value = '';
    }
    
    // Return focus
    if (this.lastFocusedElement) {
      this.lastFocusedElement.focus();
    }
    
    // Reset redeeming state when modal is closed
    this.isRedeeming = false;
  },
  
  handleRedemption: function() {
    if (this.isRedeeming) return;
    
    const button = this.redeemButton;
    const buttonText = this.buttonText;
    const spinner = this.buttonSpinner;
    const success = this.buttonSuccess;
    const codeContainer = this.codeContainer;
    
    // Set redeeming state
    this.isRedeeming = true;
    
    // Start loading state
    button.disabled = true;
    buttonText.style.display = 'none';
    spinner.style.display = 'inline-block';
    
    RivoJS.redeemReward(this.selectedProduct.id)
      .then((resp) => {
        if (resp.success) {
          // Show success checkmark
          spinner.style.display = 'none';
          success.style.display = 'inline-block';
          
          // Show redemption code
          const codeInput = this.modal.querySelector('.rivo-code-input');
          codeInput.value = resp.points_purchase.code;
          codeContainer.style.display = 'flex';
          
          // After successful redemption, update points tally and refresh cards
          RivoJS.getCustomerDetails()
            .then((customerResp) => {
              RivoRewards.customerPoints = customerResp.points_tally;
              // Reload products to ensure we have fresh data
              return RivoJS.getShopRewards();
            })
            .then((products) => {
              // Update products array with fresh data
              RivoRewards.products = products.filter(product => product.enabled === true);
              RivoRewards.refreshCardStates();
            });
          
          // After brief delay, show appropriate button text based on reward type
          setTimeout(() => {
            success.style.display = 'none';
            
            if (this.selectedProduct.reward_type === 'fixed_amount') {
              buttonText.textContent = 'Apply discount';
            } else if (this.selectedProduct.reward_type === 'free_product') {
              const variantIds = this.selectedProduct.variant_ids.split(',');
              buttonText.textContent = variantIds.length > 1 ? 
                'Apply & choose your option' : 
                'Apply & add to cart';
            }
            
            buttonText.style.display = 'inline-block';
            button.disabled = false;
          }, 1500);
        }
      })
      .catch((error) => {
        console.error('Redemption error:', error);
        // Handle error state
        spinner.style.display = 'none';
        buttonText.textContent = 'Redeem';
        buttonText.style.display = 'inline-block';
        button.disabled = false;
      })
      .finally(() => {
        // Reset redeeming state
        this.isRedeeming = false;
      });
  },
  
  applyDiscount: function() {
    const code = this.modal.querySelector('.rivo-code-input').value;
    console.log('Applying discount code:', code);

    fetch(`/discount/${code}`)
      .then(response => {
        console.log('Discount response:', response);
        return response.text();
      })
      .then(text => {
        console.log('Discount response text:', text);
        this.buttonSpinner.style.display = 'none';
        this.buttonText.textContent = 'Discount Applied!';
        this.buttonText.style.display = 'inline-block';
        
        setTimeout(() => {
          this.closeModal();
        }, 1500);
      })
      .catch(error => {
        console.error('Discount error:', error);
        this.buttonSpinner.style.display = 'none';
        this.buttonText.textContent = 'Error - Please try again';
        this.buttonText.style.display = 'inline-block';
        this.redeemButton.disabled = false;
        
        setTimeout(() => {
          this.buttonText.textContent = 'Apply discount';
        }, 2000);
      });
  },

  redirectToProductPage: function() {
    const code = this.modal.querySelector('.rivo-code-input').value;
    const productHandle = this.selectedProduct.name
      .toLowerCase()
      .replace(/[^a-z0-9]+/g, '-')
      .replace(/-+/g, '-')
      .replace(/^-|-$/g, '');

    console.log('Redirecting to:', `/products/${productHandle}`);
    console.log('Selected Product:', this.selectedProduct);

    // First apply discount, then redirect
    fetch(`/discount/${code}`)
      .then(response => {
        // After discount is applied, redirect to product page
        window.open(`/products/${productHandle}`, '_blank');
      })
      .catch(error => {
        console.error('Error applying discount:', error);
        this.buttonSpinner.style.display = 'none';
        this.buttonText.textContent = 'Error - Please try again';
        this.buttonText.style.display = 'inline-block';
        this.redeemButton.disabled = false;
      });
  },

  handleAddToCart: function() {
    const code = this.modal.querySelector('.rivo-code-input').value;
    const variantIds = this.selectedProduct.variant_ids.split(',');
    
    fetch('/cart/add.js', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json'
      },
      body: JSON.stringify({
        'items': [{
          'id': parseInt(variantIds[0], 10),
          'quantity': 1
        }]
      })
    })
    .then(response => response.json())
    .then(() => {
      window.open(`/discount/${code}?redirect=/cart`, '_blank');
    })
    .catch(error => {
      console.error('Error:', error);
      const buttonText = this.buttonText;
      const spinner = this.buttonSpinner;
      
      spinner.style.display = 'none';
      buttonText.textContent = 'Error - Please try again';
      buttonText.style.display = 'inline-block';
      this.redeemButton.disabled = false;
      
      setTimeout(() => {
        buttonText.textContent = 'Apply & add to cart';
      }, 2000);
    });
  },
  
  bindEvents: function() {
    // Close button click
    this.closeButton.addEventListener('click', () => this.closeModal());
    
    // Click outside modal
    this.modal.addEventListener('click', (e) => {
      if (e.target === this.modal) {
        this.closeModal();
      }
    });
    
    // Keyboard events
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && this.modal.classList.contains('is-active')) {
        this.closeModal();
      }
    });
    
    // Redeem button click
    this.redeemButton.addEventListener('click', () => {
      const buttonText = this.buttonText.textContent;
      
      if (buttonText === 'Apply discount') {
        this.applyDiscount();
      } else if (buttonText === 'Apply & choose your option') {
        this.redirectToProductPage();
      } else if (buttonText === 'Apply & add to cart') {
        this.handleAddToCart();
      } else {
        this.handleRedemption();
      }
    });

    // Copy code button
    const copyButton = this.modal.querySelector('.rivo-copy-code');
    copyButton.addEventListener('click', () => {
      const codeInput = this.modal.querySelector('.rivo-code-input');
      codeInput.select();
      document.execCommand('copy');
      
      // Show brief "Copied!" feedback
      const originalHTML = copyButton.innerHTML;
      copyButton.classList.add('copied');
      copyButton.innerHTML = '✓';
      
      setTimeout(() => {
        copyButton.classList.remove('copied');
        copyButton.innerHTML = originalHTML;
      }, 1000);
    });
  }
};

  
const RivoRewards = {
  currentPage: 0,
  itemsPerRow: 4,
  initialRows: {% if customer %}2{% else %}1{% endif %},
  products: [],
  preloadedImages: new Map(),
  isExpanded: false,
  customerPoints: 0,
  isRedeeming: false,
  isLoggedIn: {% if customer %}true{% else %}false{% endif %},
  
  init: function() {
    this.container = document.querySelector('.rivo-rewards-grid');
    {% if customer %}
      this.loadMoreButton = document.querySelector('.rivo-load-more');
      this.itemsCount = document.querySelector('.rivo-items-count');
    {% endif %}
    
    if (this.isLoggedIn) {
      // Get customer points before loading products
      this.loadCustomerPoints().then(() => {
        this.showSkeletonLoading();
        this.loadProducts();
        this.bindEvents();
      });
    } else {
      // Just load products for logged out view
      this.showSkeletonLoading();
      this.loadProducts();
    }
  },
  
  loadCustomerPoints: function() {
    return RivoJS.getCustomerDetails().then((resp) => {
      this.customerPoints = resp.points_tally;
    });
  },
  
  loadProducts: function() {
    RivoJS.getShopRewards().then((resp) => {
      if (!this.isLoggedIn) {
        this.products = resp
          .filter(product =>
            (product.reward_type === 'fixed_amount' || product.reward_type === 'free_product') &&
            product.enabled === true
          )
          .slice(0, 4); // Only show the first 4
      } else {
        // Original logic for logged in users
        const fixedAmountRewards = resp.filter(product => 
          product.reward_type === 'fixed_amount' && 
          product.enabled === true
        );
        
        const productRewards = resp.filter(product => 
          product.reward_type === 'free_product' && 
          product.enabled === true
        );
        
        this.products = [...fixedAmountRewards, ...productRewards];
      }
      
      // Enhanced image preloading (only for products with images)
      this.products.forEach(product => {
        if (product.icon_url) {
          const img = new Image();
          img.onload = () => {
            this.preloadedImages.set(product.icon_url, img);
            const modalImg = new Image();
            modalImg.src = product.icon_url;
            this.preloadedImages.set(`modal-${product.icon_url}`, modalImg);
          };
          img.src = product.icon_url;
          img.fetchPriority = 'high';
          img.loading = 'eager';
        }
      });
      
      this.renderInitialProducts();
      if (this.isLoggedIn) {
        this.updateLoadMoreButton();
      }
    });
  },
  
  renderInitialProducts: function() {
    const productsToShow = this.isExpanded ? this.products : this.products.slice(0, this.initialRows * this.itemsPerRow);
    this.container.innerHTML = '';
    productsToShow.forEach(this.renderProduct.bind(this));
    this.updateItemsCount();
  },
  
  renderProduct: function(product) {
    const productCard = document.createElement('div');
    productCard.className = 'rivo-reward-card';
    const hasEnoughPoints = this.isLoggedIn ? this.customerPoints >= product.points_amount : false;
    
    // Add data attributes to card
    productCard.dataset.rewardId = product.id;
    productCard.dataset.rewardType = product.reward_type;
    if (product.reward_type === 'free_product') {
      productCard.dataset.productId = product.product_id;
      productCard.dataset.variantIds = product.variant_ids;
    }
    productCard.dataset.pointsRequired = product.points_amount;
    
    // Create HTML based on reward type
    const imageHtml = product.icon_url ? `
      <div class="rivo-reward-image">
        <img 
          src="${product.icon_url}" 
          alt="${product.name}" 
          class="reward-product-image"
          width="200"
          height="200"
          style="object-fit: contain;"
        >
      </div>
    ` : `
      <div class="rivo-reward-image">
        <div class="reward-coupon-placeholder">
           ${
            product.reward_type === 'fixed_amount'
              ? `$${(product.name.match(/\d+/) || [''])[0]}`
              : product.name
          }
        </div>
      </div>
    `;
    
    productCard.innerHTML = `
      ${imageHtml}
      <div class="rivo-reward-details">
        <h3 class="reward-name">${product.name}</h3>
        <div class="reward-points">${product.pretty_points_amount} Points</div>
        {% if customer %}
          <button class="reward-add-to-cart ${!hasEnoughPoints ? 'insufficient-points' : ''}" 
            type="button"
            data-reward-id="${product.id}"
            data-reward-type="${product.reward_type}"
            data-points-required="${product.points_amount}"
            ${!hasEnoughPoints ? 'disabled' : ''}
          >
            ${hasEnoughPoints ? 'Redeem reward' : 'Not enough points'}
          </button>
        {% else %}
          <a rivo-x-on:click="window.handleWayToEarnClick" class="reward-add-to-cart">
            Redeem reward
          </a>
        {% endif %}
      </div>
    `;

    if (this.isLoggedIn && hasEnoughPoints) {
      const addToCartButton = productCard.querySelector('.reward-add-to-cart');
      addToCartButton.addEventListener('click', (e) => {
        if (RivoModal.isRedeeming) return;
        RivoModal.openModal(product, this.customerPoints);
      });
    }
    
    
    
    this.container.appendChild(productCard);
  },
  
  updateLoadMoreButton: function() {
    // Only show button if there are more than 8 items
    if (this.products.length > this.initialRows * this.itemsPerRow) {
      this.loadMoreButton.style.display = 'inline-block';
      this.loadMoreButton.textContent = this.isExpanded ? 'Show less' : 'Show more';
    } else {
      this.loadMoreButton.style.display = 'none';
    }
  },
  
  toggleProducts: function() {
    this.isExpanded = !this.isExpanded;
    this.renderInitialProducts();
    this.updateLoadMoreButton();
  },
  
  updateItemsCount: function() {
    const displayedProducts = this.isExpanded ? 
      this.products.length : 
      Math.min(this.initialRows * this.itemsPerRow, this.products.length);
    this.itemsCount.textContent = `Showing ${displayedProducts} of ${this.products.length} items`;
  },
  
  bindEvents: function() {
    if (this.isLoggedIn) {
      this.loadMoreButton.addEventListener('click', () => this.toggleProducts());
    }
  },

  showSkeletonLoading: function() {
    this.container.innerHTML = '';
    // Create 8 skeleton cards (2 rows × 4 items)
    for (let i = 0; i < this.initialRows * this.itemsPerRow; i++) {
      const skeletonCard = `
        <div class="rivo-reward-card skeleton">
          <div class="rivo-reward-image skeleton-image"></div>
          <div class="rivo-reward-details">
            <h3 class="skeleton-text skeleton-name"></h3>
            <div class="skeleton-text skeleton-points"></div>
            <button class="skeleton-button"></button>
          </div>
        </div>
      `;
      this.container.insertAdjacentHTML('beforeend', skeletonCard);
    }
    
    // Hide SHOW MORE button and count during loading
    if (this.isLoggedIn) {
      this.loadMoreButton.style.display = 'none';
      this.itemsCount.style.display = 'none';
    }
  },
  
  refreshCardStates: function() {
    console.log('Refreshing card states with points:', this.customerPoints);
    
    const rewardCards = document.querySelectorAll('.rivo-reward-card');
    rewardCards.forEach(card => {
      const button = card.querySelector('.reward-add-to-cart');
      const pointsRequired = parseInt(card.dataset.pointsRequired, 10);
      const hasEnoughPoints = this.customerPoints >= pointsRequired;
      const rewardId = card.dataset.rewardId;
      
      console.log('Card:', {
        rewardId,
        pointsRequired,
        hasEnoughPoints,
        currentPoints: this.customerPoints
      });
      
      button.textContent = hasEnoughPoints ? 'Redeem reward' : 'Not enough points';
      button.classList.toggle('insufficient-points', !hasEnoughPoints);
      button.disabled = !hasEnoughPoints;
      
      // Update click handler
      button.replaceWith(button.cloneNode(true));
      const newButton = card.querySelector('.reward-add-to-cart');
      
      if (hasEnoughPoints) {
        // Convert rewardId to string when searching
        const product = this.products.find(p => String(p.id) === String(rewardId));
        console.log('Found product:', product);
        
        if (product) {
          newButton.addEventListener('click', () => {
            console.log('Button clicked for product:', product);
            if (!RivoModal.isRedeeming) {
              RivoModal.openModal(product, this.customerPoints);
            }
          });
        }
      }
    });
  }
};

// Add Login Modal Object
const RivoLoginModal = {
  init: function() {
    this.modal = document.getElementById('rivoLoginModal');
    this.closeButton = this.modal.querySelector('.rivo-login-modal-close');
    this.bindEvents();
  },

  openModal: function() {
    this.modal.classList.add('is-active');
    document.body.classList.add('modal-open');
  },

  closeModal: function() {
    this.modal.classList.remove('is-active');
    document.body.classList.remove('modal-open');
  },

  bindEvents: function() {
    // Close button click
    this.closeButton.addEventListener('click', () => this.closeModal());

    // Click outside modal
    this.modal.addEventListener('click', (e) => {
      if (e.target === this.modal) {
        this.closeModal();
      }
    });

    // Keyboard events
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && this.modal.classList.contains('is-active')) {
        this.closeModal();
      }
    });
  }
};

// Initialize based on RivoJS availability
if (window.RivoJS) {
  {% if customer %}RivoModal.init();{% endif %}  // Initialize modal only for logged in users
  {% unless customer %}RivoLoginModal.init();{% endunless %}
  RivoRewards.init();
} else {
  document.addEventListener('rivo-js-loaded', () => {
    {% if customer %}RivoModal.init();{% endif %}  // Initialize modal only for logged in users
    {% unless customer %}RivoLoginModal.init();{% endunless %}
    RivoRewards.init();
  });
}

// Add new CSS for coupon placeholder
const newStyles = `
  .reward-coupon-placeholder {
    width: 100%;
    height: 200px;
    background-color: #e9d5cd;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 24px;
    font-weight: bold;
    color: white;

    }



  .rivo-modal-placeholder {
    width: 150px;
    height: 150px;
    background-color: #e9d5cd;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    font-weight: bold;
    color: white;
    border-radius: 4px;
    padding: 10px;
  }
`;

// Inject new styles
const styleSheet = document.createElement("style");
styleSheet.textContent = newStyles;
