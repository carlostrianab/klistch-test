      <div class="cart__media relative group" x-bind="behaviour" x-data="QuickViewButton">
        {% if settings.quick_view_enabled %}
          <button  type="button" x-cloak @click="$dispatch('toggle-quick-view', { handle: `{{ card_product.handle }}` })"
            x-bind="animation"
            aria-label="{{ 'products.product.quick_view.button' | t }}"
            class="cart__quick-view absolute top-4 right-4 md:bottom-6 md:top-auto px-0 md:px-4 rounded-full md:rounded-md w-10 h-10 flex items-center justify-center md:transform md:left-1/2 md:-translate-x-1/2 button--primary md:w-full md:max-w-max border z-20">
            <span class="hidden md:block">
              {{ 'products.product.quick_view.button' | t }}
            </span>
            <span class="md:hidden">
              {% render 'icon-cart', class: 'w-5' %}
            </span>
          </button>
        {% endif %}

        <a
          class="cursor-pointer"
          {% if enable_quick_view_bundle %} 
            x-data
            @click.prevent="$dispatch('quick-view-bundle', { handle: '{{ card_product.handle }}' })" 
          {% else %} 
            href="{{ card_product.url | default: '#' }}" 
          {% endif %}
          aria-label="{{ card_product.title }}">
          {%- if card_product.featured_media -%}
            {% render 'img-medium', image: card_product.featured_media, position: position, loading: image_loading %}
            {% if card_product.media[1] != blank and show_secondary_image %}
              {% render 'img-medium', image: card_product.media[1], class: ' absolute z-10 top-0 left-0 h-full w-full object-cover opacity-0 group-hover:opacity-100 ' %}
            {% endif %}

          {%- endif -%}
          {% render 'product-flags', product_item: card_product %}
        </a>

        {% if show_sold_count and card_product.metafields.custom.sold_units != blank %}
          {% assign sold_count = card_product.metafields.custom.sold_units %}
          {% assign k_count = sold_count | divided_by: 1000 %}
          {% assign m_count = sold_count | divided_by: 1000000 %}
          {% if sold_count >= 1000000 %}
              {% assign m_count = m_count | round: 1 %}
              {% assign sold_count = m_count | append: 'M+' %}
          {% elsif sold_count >= 1000 %}
              {% assign k_count = k_count | round: 1 %}
              {% assign sold_count = k_count | append: 'K+' %}
          {% endif %}

          <div class="overflow-hidden text-right text-sm units-sold absolute bottom-3 left-2 z-[100] bg-white px-2 py-0.5 rounded-md border border-black font-medium leading-[normal]">
              {{ 'products.product.sold_count' | t: count: sold_count }} 
          </div>

        {% endif %}

      </div>
      
      <a 
      {% if enable_quick_view_bundle %} 
        x-data
        @click.prevent="$dispatch('quick-view-bundle', { handle: '{{ card_product.handle }}' })" 
      {% else %} 
        href="{{ card_product.url | default: '#' }}" 
      {% endif %}
       class="card__content block cursor-pointer  {% if show_add_to_cart %} pt-4 {% else %} py-4 {% endif %} text-center space-y-1">
          <p class="card__heading font-medium">
            {{ card_product.title | escape }}
          </p>
          <div class="flex justify-center gap-2 items-center">

            {%- if show_rating -%}
              {% render 'review-snippet' product: card_product, compact_reviews:compact_reviews  %}
            {%- endif -%}

          </div>
          <div class="card__information">
            <div class="cart__price">
              {% render 'price', product: card_product, price_class: "justify-center font-medium" %}
            </div>

            {% if settings.show_product_excerpt and card_product.metafields.custom.product_excerpt != blank %}
              <div class="py-1 opacity-70 text-sm">
                {{ card_product.metafields.custom.product_excerpt |  metafield_tag }}
              </div>
            {% endif %}

          </div>
      </a>
        
      <div class="cart__actions mt-auto">
        {% render 'add-to-cart', product: card_product, show_quantity: false, show_subscription: true %}
      </div>

  </div>
{%- else -%}
  <div class="card-wrapper">
    <div class="card">
      <div class="cart__media border">
        {%- assign random_number = "now" | date: "%N" | modulo: 5 | plus: 1 -%}
        {% assign product_name = random_number | prepend: 'product-' %}
        {{ product_name | placeholder_svg_tag }}
      </div>

      <div class="card__content py-4">
        <h3 class="card__heading font-medium">
          <a role="link" aria-disabled="true" class="">
            {{ 'onboarding.product_title' | t }}
          </a>
        </h3>

        <div class="cart__information">
          {%- if show_vendor -%}
            <span class="sr-only">{{ 'accessibility.vendor' | t }}</span>
            <div class="cart__information-vendor">{{ 'products.product.vendor' | t }}</div>
          {%- endif -%}
          {% render 'price' %}
        </div>

      </div>

    </div>
  </div>
{%- endif -%}


