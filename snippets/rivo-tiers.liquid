{% assign vip_tier = customer.metafields.custom.rivo.value.vip_tier %}
{% assign tiers = shop.metafields.rivo.loy.vip_program.tiers %}
{% assign tier1 = tiers[0].name %}
{% assign tier2 = tiers[1].name %}
{% assign tier3 = tiers[2].name %}

<div class="rivo-vip_row">
  <!-- TIER 1 -->
  <div class="rivo-vip_card">
    <div class="rivo-vip_header">
      <p class="rivo-vip_rule">Free to Join!</p>
      <h3 class="rivo-vip_name">{{ tier1 }}</h3>
    </div>
    <p class="rivo-vip_card-content">
      Earn <span class="rivo-font-sophillia">10</span> Kitsch points for every $1 USD spent
    </p>
  </div>
  <!-- TIER 2 -->
  <div class="rivo-vip_card">
    <div class="rivo-vip_header">
      <p class="rivo-vip_rule">Spend $50</p>
      <h3 class="rivo-vip_name">{{ tier2 }}</h3>
    </div>
    <p class="rivo-vip_card-content">
      Earn <span class="rivo-font-sophillia">15</span> Kitsch points for every $1 USD spent
    </p>
  </div>
  <!-- TIER 3 -->
  <div class="rivo-vip_card">
    <div class="rivo-vip_header">
      <p class="rivo-vip_rule">Spend $100</p>
      <h3 class="rivo-vip_name">{{ tier3 }}</h3>
    </div>
    <p class="rivo-vip_card-content">
      Earn <span class="rivo-font-sophillia">20</span> Kitsch points for every $1 USD spent
    </p>
  </div>
</div>

{% comment %}
  On mobile, display the active VIP Tier first
{% endcomment %}

<style>
  .rivo-vip_row {
    display: flex;
    overflow-x: auto;
    padding: 40px 0;
    width: 80%;
    margin: 0 auto;
    margin-top: 40px;
  }
  
  @media only screen and (max-width: 1100px) {
    .rivo-vip_row {
      width: 100%;
    }
  }
  
  .rivo-vip_card {
    flex: 1;
    /* distribute the space equally among the cards */
    width: calc(33.3333% - 10px);
    /* each card takes up roughly a third, minus a bit for the margin */
    margin-right: 15px;
    /* space between cards */
    background-size: cover;
    background-position: center;
    text-align: center;
    background: #FFF;
    border: 1.5px solid #000;
    border-radius: 0.375rem
  }
  
  
  .rivo-vip_header {
    background: #f3f3f3;
    padding: 15px;
    border-radius: 0.375rem 0.375rem 0 0;
  }
  
  
  .rivo-vip_row .rivo-vip_card:last-child {
    margin-right: 0;
    /* remove margin from the last card to ensure it doesn't overflow */
  }
  
  .rivo-vip_card h3 {
    margin: 0.5rem 0;
    font-size: 30px !important;
    font-family: 'Sophillia';
  }
  
  
  .rivo-vip_rule {
    font-size: 16px;
    margin: 0;
    text-transform: uppercase;
    margin: 8px 0;
    margin-top: 16px;
  }
  
  .rivo-vip_card-content {
    padding: 50px 35px;
    font-size: 24px;
  }
  
  .rivo-font-sophillia {
    font-family: 'Sophillia';
  }
  
  @media only screen and (max-width: 900px) {
    .rivo-vip_row {
      display: flex;
      overflow-x: scroll;
      /* Allows horizontal scrolling */
      -webkit-overflow-scrolling: touch;
      /* Smooth scrolling for iOS */
      width: 100%;
      scroll-snap-type: x mandatory;
    }
  
    .rivo-vip_card {
      flex: none;
      width: 55%;
      margin-right: 10px;
      scroll-snap-align: start;
    }
  
    .rivo-vip_card-content {
      padding: 20px;
      font-size: 20px;
    }
  
    .rivo-vip_row .rivo-vip_card:last-child {
      margin-right: 10px;
    }
  
    .rivo-vip_list {
      padding: 20px;
    }
  
    .rivo-vip_rule {
      margin: 0 !important;
    }
  
    .rivo-vip_card ul {
      padding-left: 15px !important;
    }
  
    /* Reorder cards based on vip_tier */
    {% if vip_tier == tier2 %}
      .rivo-vip_row > .rivo-vip_card:nth-child(1) {
        order: 2;
      }
      .rivo-vip_row > .rivo-vip_card:nth-child(2) {
        order: 1;
      }
      .rivo-vip_row > .rivo-vip_card:nth-child(3) {
        order: 3;
      }
    {% elsif vip_tier == tier3 %}
      .rivo-vip_row > .rivo-vip_card:nth-child(1) {
        order: 2;
      }
      .rivo-vip_row > .rivo-vip_card:nth-child(2) {
        order: 3;
      }
      .rivo-vip_row > .rivo-vip_card:nth-child(3) {
        order: 1;
      }
    {% endif %}
   }
  
   /* Highlighting the active TIER */
  {% if vip_tier == tier1 %}
    .rivo-vip_row > .rivo-vip_card:nth-child(1) {
      box-shadow: 5px 5px 9px -1px rgba(0,0,0,0.41);
    }
    .rivo-vip_row > .rivo-vip_card:nth-child(1) .rivo-vip_header {
      background: #E9D5CD;
    }
  {% elsif vip_tier == tier2 %}
    .rivo-vip_row > .rivo-vip_card:nth-child(2) {
      box-shadow: 5px 5px 9px -1px rgba(0,0,0,0.41);
    }
    .rivo-vip_row > .rivo-vip_card:nth-child(2) .rivo-vip_header {
      background: #E9D5CD;
    }
  {% elsif vip_tier == tier3 %}
    .rivo-vip_row > .rivo-vip_card:nth-child(3) {
      box-shadow: 5px 5px 9px -1px rgba(0,0,0,0.41);
    }
    .rivo-vip_row > .rivo-vip_card:nth-child(3) .rivo-vip_header {
      background: #E9D5CD;
    }
  {% endif %}
</style>

