<div class="currency-selector__dropdown absolute border bg-white overflow-auto no-scrollbar shadow-lg z-30 p-3 w-72 h-72 right-4 {{ class }}"
    x-show="openCurrency"
    x-cloak
    x-transition:enter="transition ease-out duration-200"
    x-transition:enter-start="opacity-0 transform scale-90"
    x-transition:enter-end="opacity-100 transform scale-100"
    x-transition:leave="transition ease-in duration-75"
    x-transition:leave-start="opacity-100 transform scale-100"
    x-transition:leave-end="opacity-0 transform scale-90">

    {% form 'localization', x-ref: "currencyForm" %}
        {% assign highlighted_countries = highlighted_countries | split: ',' %}
        <style>
            {%- for item in highlighted_countries -%}
                [data-order="{{- item -}}"] {
                    order: {{- forloop.index -}};
                    {%- if forloop.last -%}
                    border-bottom: 1px solid #000;
                    padding-bottom: 0.5rem;
                    margin-bottom: 0.5rem;
                    {%- endif -%}
                }
            {%- endfor -%}
        </style>

        <ul class="currency-selector__list flex flex-col gap-2">
            {% for country in localization.available_countries %}
                <li class="disclosure__item  order-last" tabindex="-1" data-order="{{ country.iso_code }}">
                    <button type="button" class="text-left flex items-center gap-2 font-medium uppercase hover:underline"
                        @click="country_code = '{{ country.iso_code }}'; openCurrency = false;"
                        {% if country.iso_code == localization.country.iso_code %}
                            aria-current="true"
                        {% endif %}
                        data-value="{{ country.iso_code }}">
                        <span class="rounded-full w-5 h-5 bg-cover fi fi-{{ country.iso_code | downcase }}"></span>
                        {{ country.name }} ({{ country.currency.iso_code }} {{ country.currency.symbol }})
                    </button>
                </li>
            {% endfor %}
        </ul>
        <input type="hidden" x-model="country_code" name="country_code" value="{{ localization.country.iso_code }}">
    {% endform %}

</div>
